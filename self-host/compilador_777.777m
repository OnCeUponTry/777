R 0 0 Call [elf_emit_at, p, 255]
R 0 0 Add [base, 15] p
R 0 0 Call [elf_emit_at, p, 36]
R 0 0 Add [base, 16] p
R 0 0 Call [elf_emit_at, p, 193]
R 0 0 Ret []
R 0 0 EndF

# Emit epilogo: mov rdi,r12; mov rax,60; syscall
F 0 0 arch_emit_tail [base]
R 0 0 Call [elf_emit_at, base, 76]
R 0 0 Add [base, 1] p
R 0 0 Call [elf_emit_at, p, 137]
R 0 0 Add [base, 2] p
R 0 0 Call [elf_emit_at, p, 231]
