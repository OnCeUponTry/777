# F.8 m_elf - build_vm_elf (paralelo compilador_777.c 857-1064)
# ============================================================================
# Tabla buffer global para handler_offsets (en C era local int[64], aqui global).
R 0 0 Alloc [c_HANDLER_TABLE_BYTES] elf_handler_offsets

# void build_vm_elf()
F 0 0 build_vm_elf []
R 0 0 Call [arch_setup_size] setup_size
R 0 0 Call [arch_dispatch_size] dloop_size
R 0 0 Call [arch_jmp_back_size] jb_size
R 0 0 Call [arch_jt_entry_bytes] jte_bytes
R 0 0 Call [arch_tail_size] tail_size_v
R 0 0 Call [arch_base_vaddr] base_vaddr_v
R 0 0 Add [setup_size, dloop_size] cur
# Compute handler_offsets per opcode
R 0 0 Add [0, 0] i
R 0 0 Label [bve_off_loop]
R 0 0 Lt [i, c_NUM_OPCODES] cond
R 0 0 Jz [cond, bve_off_done]
R 0 0 Mul [i, 8] ioff
R 0 0 StoreI64 [elf_handler_offsets, ioff, cur]
R 0 0 Call [arch_handler_size, i] hbytes_len
R 0 0 Call [arch_handler_is_halt, i] is_halt
R 0 0 Jz [is_halt, bve_chk_exit]
R 0 0 Add [cur, jb_size] cur
R 0 0 Jmp [bve_off_next]
R 0 0 Label [bve_chk_exit]
R 0 0 Call [arch_handler_is_exit, i] is_exit
R 0 0 Jz [is_exit, bve_normal]
R 0 0 Add [cur, hbytes_len] cur
R 0 0 Jmp [bve_off_next]
R 0 0 Label [bve_normal]
R 0 0 Add [cur, hbytes_len] cur
R 0 0 Add [cur, jb_size] cur
R 0 0 Label [bve_off_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [bve_off_loop]
R 0 0 Label [bve_off_done]
R 0 0 Add [cur, 0] tail_offset
R 0 0 Add [tail_offset, tail_size_v] vm_code_size
R 0 0 Add [vm_code_size, 0] jt_offset
R 0 0 Mul [c_NUM_OPCODES, jte_bytes] jt_size_v
R 0 0 Add [jt_offset, jt_size_v] vars_offset
R 0 0 Add [vars_offset, c_VARS_AREA_SIZE] bc_offset
R 0 0 Add [c_HEADER_TOTAL, bc_offset] tmp1
R 0 0 Add [tmp1, g_bytecode_len] total_file_size
R 0 0 Add [total_file_size, 0] g_elf_len
# Zero g_elf buffer hasta total_file_size
R 0 0 Add [0, 0] i
R 0 0 Label [bve_zero]
R 0 0 Lt [i, total_file_size] cond
R 0 0 Jz [cond, bve_zdone]
R 0 0 StoreByte [g_elf, i, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [bve_zero]
R 0 0 Label [bve_zdone]
# entry = base_vaddr + HEADER_TOTAL
R 0 0 Add [base_vaddr_v, c_HEADER_TOTAL] entry
# ELF header magic
R 0 0 StoreByte [g_elf, 0, 127]
R 0 0 StoreByte [g_elf, 1, 69]
R 0 0 StoreByte [g_elf, 2, 76]
R 0 0 StoreByte [g_elf, 3, 70]
R 0 0 StoreByte [g_elf, 4, 2]
R 0 0 StoreByte [g_elf, 5, 1]
R 0 0 StoreByte [g_elf, 6, 1]
# e_type, e_machine, e_version, e_entry, e_phoff, e_shoff, e_flags, e_ehsize, e_phentsize, e_phnum
R 0 0 Call [elf_emit_u16_at, 16, 2]
R 0 0 Call [arch_e_machine] em
R 0 0 Call [elf_emit_u16_at, 18, em]
R 0 0 Call [elf_emit_u32_at, 20, 1]
R 0 0 Call [elf_emit_u64_at, 24, entry]
R 0 0 Call [elf_emit_u64_at, 32, 64]
R 0 0 Call [elf_emit_u64_at, 40, 0]
R 0 0 Call [elf_emit_u32_at, 48, 0]
R 0 0 Call [elf_emit_u16_at, 52, 64]
R 0 0 Call [elf_emit_u16_at, 54, 56]
R 0 0 Call [elf_emit_u16_at, 56, 1]
# Program header
R 0 0 Call [elf_emit_u32_at, 64, 1]
R 0 0 Call [elf_emit_u32_at, 68, 7]
R 0 0 Call [elf_emit_u64_at, 72, 0]
R 0 0 Call [elf_emit_u64_at, 80, base_vaddr_v]
R 0 0 Call [elf_emit_u64_at, 88, base_vaddr_v]
R 0 0 Call [elf_emit_u64_at, 96, total_file_size]
R 0 0 Call [elf_emit_u64_at, 104, total_file_size]
R 0 0 Call [elf_emit_u64_at, 112, 4096]
# vm_base = HEADER_TOTAL
R 0 0 Add [c_HEADER_TOTAL, 0] vm_base
# Setup: lea r15 displacements
R 0 0 Add [vm_base, 10] lea_r15_post
R 0 0 Add [vm_base, bc_offset] bc_abs
R 0 0 Sub [bc_abs, lea_r15_post] disp_bc
R 0 0 Add [vm_base, 17] lea_rbp_post
R 0 0 Add [vm_base, vars_offset] vars_abs
R 0 0 Sub [vars_abs, lea_rbp_post] disp_vars
R 0 0 Call [arch_emit_setup, vm_base, disp_bc, disp_vars]
# Dispatch loop
R 0 0 Add [vm_base, setup_size] dloop_abs
R 0 0 Add [dloop_abs, 14] lea_rcx_post
R 0 0 Add [vm_base, jt_offset] jt_abs
R 0 0 Sub [jt_abs, lea_rcx_post] disp_jt
R 0 0 Call [arch_emit_dispatch, dloop_abs, disp_jt]
# Handlers loop
R 0 0 Add [vm_base, tail_offset] tail_abs
R 0 0 Add [0, 0] i
R 0 0 Label [bve_h_loop]
R 0 0 Lt [i, c_NUM_OPCODES] cond
R 0 0 Jz [cond, bve_h_done]
R 0 0 Mul [i, 8] ioff
R 0 0 LoadI64 [elf_handler_offsets, ioff] h_off
R 0 0 Add [vm_base, h_off] h_abs
R 0 0 Call [arch_handler_ptr, i] hbytes_ptr
R 0 0 Call [arch_handler_size, i] hbytes_len
R 0 0 Call [arch_handler_is_halt, i] is_halt
R 0 0 Jz [is_halt, bve_h_chk_exit]
R 0 0 Add [h_abs, jb_size] h_post
R 0 0 Sub [tail_abs, h_post] disp_h
R 0 0 Call [arch_emit_halt_jmp, h_abs, disp_h]
R 0 0 Jmp [bve_h_next]
R 0 0 Label [bve_h_chk_exit]
R 0 0 Call [arch_handler_is_exit, i] is_exit
R 0 0 Jz [is_exit, bve_h_normal]
# Exit handler: copia bytes, no jmp back.
R 0 0 Add [0, 0] j
R 0 0 Label [bve_h_excopy]
R 0 0 Lt [j, hbytes_len] cond
R 0 0 Jz [cond, bve_h_next]
R 0 0 LoadByte [hbytes_ptr, j] b
R 0 0 Add [h_abs, j] dst
R 0 0 Call [elf_emit_at, dst, b]
R 0 0 Add [j, 1] j
R 0 0 Jmp [bve_h_excopy]
R 0 0 Label [bve_h_normal]
# Normal handler: copia bytes + jmp back a dispatch.
R 0 0 Add [0, 0] j
R 0 0 Label [bve_h_ncopy]
R 0 0 Lt [j, hbytes_len] cond
R 0 0 Jz [cond, bve_h_njmp]
R 0 0 LoadByte [hbytes_ptr, j] b
R 0 0 Add [h_abs, j] dst
R 0 0 Call [elf_emit_at, dst, b]
R 0 0 Add [j, 1] j
R 0 0 Jmp [bve_h_ncopy]
R 0 0 Label [bve_h_njmp]
R 0 0 Add [h_abs, hbytes_len] jmp_pos
R 0 0 Add [jmp_pos, jb_size] jmp_post
R 0 0 Sub [dloop_abs, jmp_post] disp_j
R 0 0 Call [arch_emit_jmp_back, jmp_pos, disp_j]
R 0 0 Label [bve_h_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [bve_h_loop]
R 0 0 Label [bve_h_done]
# Tail
R 0 0 Call [arch_emit_tail, tail_abs]
# Jump table: abs addrs to handlers.
R 0 0 Add [0, 0] i
R 0 0 Label [bve_jt_loop]
R 0 0 Lt [i, c_NUM_OPCODES] cond
R 0 0 Jz [cond, bve_jt_done]
R 0 0 Mul [i, 8] ioff
R 0 0 LoadI64 [elf_handler_offsets, ioff] h_off
R 0 0 Add [base_vaddr_v, vm_base] tmp2
R 0 0 Add [tmp2, h_off] abs_addr
R 0 0 Mul [i, jte_bytes] jtidx_off
R 0 0 Add [vm_base, jt_offset] jtbase
R 0 0 Add [jtbase, jtidx_off] jt_pos
R 0 0 Call [elf_emit_u64_at, jt_pos, abs_addr]
R 0 0 Add [i, 1] i
R 0 0 Jmp [bve_jt_loop]
R 0 0 Label [bve_jt_done]
# Bytecode copy
R 0 0 Add [0, 0] i
R 0 0 Label [bve_bc_loop]
R 0 0 Lt [i, g_bytecode_len] cond
R 0 0 Jz [cond, bve_bc_done]
R 0 0 LoadByte [g_bytecode, i] b
R 0 0 Add [vm_base, bc_offset] bc_base
R 0 0 Add [bc_base, i] dst
R 0 0 Call [elf_emit_at, dst, b]
R 0 0 Add [i, 1] i
R 0 0 Jmp [bve_bc_loop]
R 0 0 Label [bve_bc_done]
R 0 0 Ret []
R 0 0 EndF

# ============================================================================
# F.11 m_parser_d - compile_line_D (paralelo compilador_777.c 1852-1968)
# ============================================================================
# Procesa "D <id> <id> <name> Integer <val>" o "D ... Text \"...\"".
# Asume parse_pos esta tras 'D'. Avanza hasta despues '\n'.

D 0 0 c_kind_Integer Text "Integer\0"
D 0 0 c_kind_Text Text "Text\0"

F 0 0 compile_line_D [end]
R 0 0 Add [parse_pos, 0] line_end
R 0 0 Label [cld_find_eol]
R 0 0 Lt [line_end, end] cond
R 0 0 Jz [cond, cld_eol_done]
R 0 0 LoadByte [g_source, line_end] cc
R 0 0 Eq [cc, 10] is_nl
R 0 0 Jz [is_nl, cld_eol_inc]
R 0 0 Jmp [cld_eol_done]
R 0 0 Label [cld_eol_inc]
R 0 0 Add [line_end, 1] line_end
R 0 0 Jmp [cld_find_eol]
R 0 0 Label [cld_eol_done]
# id1
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, cld_tok2]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_tok2]
# id2
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, cld_tok3]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_tok3]
# name
R 0 0 Call [next_token, line_end]
R 0 0 Call [is_valid_ident_at, g_tok_off, g_tok_len] is_id
R 0 0 Jz [is_id, cld_skip]
R 0 0 Label [cld_intern]
R 0 0 Add [g_source, g_tok_off] name_ptr
R 0 0 Call [sym_intern, name_ptr, g_tok_len] slot
R 0 0 Lt [slot, 0] bad_slot
R 0 0 Jz [bad_slot, cld_type]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_type]
# type token
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, cld_chk_text]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_chk_text]
R 0 0 Call [eq_str_lit, g_tok_off, g_tok_len, c_kind_Text] is_text
R 0 0 Jz [is_text, cld_integer]
# Text path: next token = quoted string.
R 0 0 Call [next_token, line_end]
R 0 0 Lt [g_tok_len, 2] too_short
R 0 0 Jz [too_short, cld_text_check]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_text_check]
R 0 0 LoadByte [g_source, g_tok_off] b0
R 0 0 Eq [b0, 34] open_q
R 0 0 Jz [open_q, cld_skip]
R 0 0 Sub [g_tok_len, 1] last_idx
R 0 0 Add [g_tok_off, last_idx] last_pos
R 0 0 LoadByte [g_source, last_pos] b_last
R 0 0 Eq [b_last, 34] close_q
R 0 0 Jz [close_q, cld_skip]
# Procesar escapes raw[1..len-1] -> str_tmp
R 0 0 Add [g_tok_off, 1] raw_off
R 0 0 Sub [g_tok_len, 2] content_len
R 0 0 Add [0, 0] i
R 0 0 Add [0, 0] j
R 0 0 Label [cld_esc_loop]
R 0 0 Lt [i, content_len] cond
R 0 0 Jz [cond, cld_esc_done]
R 0 0 Add [raw_off, i] ri
R 0 0 LoadByte [g_source, ri] b
R 0 0 Eq [b, 92] is_bs
R 0 0 Jz [is_bs, cld_lit]
R 0 0 Add [i, 1] inext
R 0 0 Lt [inext, content_len] has_next
R 0 0 Jz [has_next, cld_lit]
R 0 0 Add [raw_off, inext] r_esc
R 0 0 LoadByte [g_source, r_esc] esc
R 0 0 Eq [esc, 110] is_n
R 0 0 Jz [is_n, cld_chk_t]
R 0 0 StoreByte [str_tmp, j, 10]
R 0 0 Jmp [cld_esc_adv]
R 0 0 Label [cld_chk_t]
R 0 0 Eq [esc, 116] is_t
R 0 0 Jz [is_t, cld_chk_bs]
R 0 0 StoreByte [str_tmp, j, 9]
R 0 0 Jmp [cld_esc_adv]
R 0 0 Label [cld_chk_bs]
R 0 0 Eq [esc, 92] is_bb
R 0 0 Jz [is_bb, cld_chk_quo]
R 0 0 StoreByte [str_tmp, j, 92]
R 0 0 Jmp [cld_esc_adv]
R 0 0 Label [cld_chk_quo]
R 0 0 Eq [esc, 34] is_q
R 0 0 Jz [is_q, cld_chk_zero]
R 0 0 StoreByte [str_tmp, j, 34]
R 0 0 Jmp [cld_esc_adv]
R 0 0 Label [cld_chk_zero]
R 0 0 Eq [esc, 48] is_z
R 0 0 Jz [is_z, cld_chk_r]
R 0 0 StoreByte [str_tmp, j, 0]
R 0 0 Jmp [cld_esc_adv]
R 0 0 Label [cld_chk_r]
R 0 0 Eq [esc, 114] is_r
R 0 0 Jz [is_r, cld_skip]
R 0 0 StoreByte [str_tmp, j, 13]
R 0 0 Jmp [cld_esc_adv]
R 0 0 Label [cld_esc_adv]
R 0 0 Add [j, 1] j
R 0 0 Add [i, 2] i
R 0 0 Jmp [cld_esc_loop]
R 0 0 Label [cld_lit]
R 0 0 StoreByte [str_tmp, j, b]
R 0 0 Add [j, 1] j
R 0 0 Add [i, 1] i
R 0 0 Jmp [cld_esc_loop]
R 0 0 Label [cld_esc_done]
R 0 0 Call [str_intern, str_tmp, j] data_off
R 0 0 Lt [data_off, 0] err_intern
R 0 0 Jz [err_intern, cld_text_emit]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_text_emit]
R 0 0 Call [bc_emit, 22]
R 0 0 Add [g_bytecode_len, 0] fixup_pos
R 0 0 Call [bc_emit_imm64, 0]
R 0 0 Call [str_add_fixup, fixup_pos, data_off] af_r
R 0 0 Eq [af_r, 0] ok
R 0 0 Jz [ok, cld_skip]
R 0 0 Call [bc_emit, 7]
R 0 0 Call [bc_emit_slot, slot]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_integer]
# Integer path: next token = numero.
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, cld_int_parse]
R 0 0 Jmp [cld_skip]
R 0 0 Label [cld_int_parse]
R 0 0 Call [parse_i64_at, g_tok_off, g_tok_len] val
R 0 0 Eq [g_parse_err, 0] ok
R 0 0 Jz [ok, cld_skip]
R 0 0 Label [cld_int_emit]
R 0 0 Call [fits_in_i32, val] is32
R 0 0 Jz [is32, cld_int_64]
R 0 0 Call [bc_emit, 1]
R 0 0 Call [bc_emit_imm32, val]
R 0 0 Jmp [cld_int_store]
R 0 0 Label [cld_int_64]
R 0 0 Call [bc_emit, 22]
R 0 0 Call [bc_emit_imm64, val]
R 0 0 Label [cld_int_store]
R 0 0 Call [bc_emit, 7]
R 0 0 Call [bc_emit_slot, slot]
R 0 0 Label [cld_skip]
R 0 0 Call [skip_to_eol, end]
R 0 0 Ret [0]
R 0 0 EndF

# ============================================================================
# F.12 m_parser_f - compile_line_F (paralelo compilador_777.c 1975-2050)
# ============================================================================
F 0 0 compile_line_F [end]
# Fallback Sub-G: si F previa abierta, patchearla ahora antes de abrir nueva.
R 0 0 Lt [pending_fn_jmp_pos, 0] no_pending
R 0 0 Jz [no_pending, clf_patch_prev]
R 0 0 Jmp [clf_after_patch]
R 0 0 Label [clf_patch_prev]
R 0 0 Add [pending_fn_jmp_pos, 2] post
R 0 0 Sub [g_bytecode_len, post] rel
R 0 0 BitAnd [rel, 255] rb0
R 0 0 StoreByte [g_bytecode, pending_fn_jmp_pos, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 BitAnd [rs, 255] rb1
R 0 0 Add [pending_fn_jmp_pos, 1] pos1
R 0 0 StoreByte [g_bytecode, pos1, rb1]
R 0 0 Add [-1, 0] pending_fn_jmp_pos
R 0 0 Label [clf_after_patch]
R 0 0 Add [-1, 0] pending_fn_slot
# Sub-C reciclaje: restaurar sym_count tras cerrar F previa (fallback sin EndF).
R 0 0 Lt [0, fn_slot_alloc_start] has_snap
R 0 0 Jz [has_snap, clf_no_recycle]
R 0 0 Add [fn_slot_alloc_start, 0] sym_count
R 0 0 Add [0, 0] fn_slot_alloc_start
R 0 0 Label [clf_no_recycle]
# Find line_end
R 0 0 Add [parse_pos, 0] line_end
R 0 0 Label [clf_find_eol]
R 0 0 Lt [line_end, end] cond
R 0 0 Jz [cond, clf_eol_done]
R 0 0 LoadByte [g_source, line_end] cc
R 0 0 Eq [cc, 10] is_nl
R 0 0 Jz [is_nl, clf_eol_inc]
R 0 0 Jmp [clf_eol_done]
R 0 0 Label [clf_eol_inc]
R 0 0 Add [line_end, 1] line_end
R 0 0 Jmp [clf_find_eol]
R 0 0 Label [clf_eol_done]
# Skip ws
R 0 0 Label [clf_skip_ws1]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_skip_row]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] is_sp
R 0 0 Jz [is_sp, clf_chk_t1]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_skip_ws1]
R 0 0 Label [clf_chk_t1]
R 0 0 Eq [cc, 9] is_t
R 0 0 Jz [is_t, clf_skip_row]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_skip_ws1]
R 0 0 Label [clf_skip_row]
# Skip row digits
R 0 0 Label [clf_row_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_skip_ws2]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Lt [cc, 48] lo
R 0 0 Jz [lo, clf_row_chk_hi]
R 0 0 Jmp [clf_skip_ws2]
R 0 0 Label [clf_row_chk_hi]
R 0 0 Gt [cc, 57] hi
R 0 0 Jz [hi, clf_row_adv]
R 0 0 Jmp [clf_skip_ws2]
R 0 0 Label [clf_row_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_row_loop]
R 0 0 Label [clf_skip_ws2]
R 0 0 Label [clf_skip_ws2_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_skip_col]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] is_sp
R 0 0 Jz [is_sp, clf_chk_t2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_skip_ws2_loop]
R 0 0 Label [clf_chk_t2]
R 0 0 Eq [cc, 9] is_t
R 0 0 Jz [is_t, clf_skip_col]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_skip_ws2_loop]
R 0 0 Label [clf_skip_col]
# Skip col digits
R 0 0 Label [clf_col_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_skip_ws3]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Lt [cc, 48] lo
R 0 0 Jz [lo, clf_col_chk_hi]
R 0 0 Jmp [clf_skip_ws3]
R 0 0 Label [clf_col_chk_hi]
R 0 0 Gt [cc, 57] hi
R 0 0 Jz [hi, clf_col_adv]
R 0 0 Jmp [clf_skip_ws3]
R 0 0 Label [clf_col_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_col_loop]
R 0 0 Label [clf_skip_ws3]
R 0 0 Label [clf_skip_ws3_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_parse_name]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] is_sp
R 0 0 Jz [is_sp, clf_chk_t3]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_skip_ws3_loop]
R 0 0 Label [clf_chk_t3]
R 0 0 Eq [cc, 9] is_t
R 0 0 Jz [is_t, clf_parse_name]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_skip_ws3_loop]
R 0 0 Label [clf_parse_name]
# Parse name hasta ws o '['
R 0 0 Add [parse_pos, 0] name_start
R 0 0 Label [clf_name_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_name_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s1
R 0 0 Jz [s1, clf_n_t]
R 0 0 Jmp [clf_name_done]
R 0 0 Label [clf_n_t]
R 0 0 Eq [cc, 9] s2
R 0 0 Jz [s2, clf_n_b]
R 0 0 Jmp [clf_name_done]
R 0 0 Label [clf_n_b]
R 0 0 Eq [cc, 91] s3
R 0 0 Jz [s3, clf_n_adv]
R 0 0 Jmp [clf_name_done]
R 0 0 Label [clf_n_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_name_loop]
R 0 0 Label [clf_name_done]
R 0 0 Sub [parse_pos, name_start] nlen
R 0 0 Lt [0, nlen] valid
R 0 0 Jz [valid, clf_skip]
R 0 0 Add [g_source, name_start] name_ptr
R 0 0 Call [func_lookup_or_create, name_ptr, nlen] slot
R 0 0 Lt [slot, 0] bad
R 0 0 Jz [bad, clf_activate]
R 0 0 Jmp [clf_skip]
R 0 0 Label [clf_activate]
# Activate scope local Sub-C ANTES de parse params (params seran locales)
R 0 0 Add [slot, 0] pending_fn_slot
# Sub-C reciclaje: snapshot sym_count para restaurar al cerrar F
R 0 0 Add [sym_count, 0] fn_slot_alloc_start
# Parse params [p1,p2,...]
R 0 0 Mul [slot, c_MAX_PARAMS_PER_FN] param_base
R 0 0 Add [0, 0] param_count
R 0 0 Label [clf_p_skip_ws]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_emit_jmp]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s1
R 0 0 Jz [s1, clf_p_t]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_skip_ws]
R 0 0 Label [clf_p_t]
R 0 0 Eq [cc, 9] s2
R 0 0 Jz [s2, clf_p_chk_br]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_skip_ws]
R 0 0 Label [clf_p_chk_br]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_emit_jmp]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, clf_emit_jmp]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Label [clf_p_loop]
R 0 0 Label [clf_p_inner_ws]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_p_emit]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s1
R 0 0 Jz [s1, clf_p_iws_t]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_inner_ws]
R 0 0 Label [clf_p_iws_t]
R 0 0 Eq [cc, 9] s2
R 0 0 Jz [s2, clf_p_chk_close]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_inner_ws]
R 0 0 Label [clf_p_chk_close]
R 0 0 Eq [cc, 93] is_close
R 0 0 Jz [is_close, clf_p_pname]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_emit]
R 0 0 Label [clf_p_pname]
# Parse param name hasta ws/coma/']'
R 0 0 Add [parse_pos, 0] pname_start
R 0 0 Label [clf_p_nloop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_p_intern]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, clf_p_chk_t]
R 0 0 Jmp [clf_p_intern]
R 0 0 Label [clf_p_chk_t]
R 0 0 Eq [cc, 9] s
R 0 0 Jz [s, clf_p_chk_co]
R 0 0 Jmp [clf_p_intern]
R 0 0 Label [clf_p_chk_co]
R 0 0 Eq [cc, 44] s
R 0 0 Jz [s, clf_p_chk_clb]
R 0 0 Jmp [clf_p_intern]
R 0 0 Label [clf_p_chk_clb]
R 0 0 Eq [cc, 93] s
R 0 0 Jz [s, clf_p_n_adv]
R 0 0 Jmp [clf_p_intern]
R 0 0 Label [clf_p_n_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_nloop]
R 0 0 Label [clf_p_intern]
R 0 0 Sub [parse_pos, pname_start] plen
R 0 0 Lt [0, plen] pvalid
R 0 0 Jz [pvalid, clf_p_after]
R 0 0 Lt [param_count, c_MAX_PARAMS_PER_FN] cap
R 0 0 Jz [cap, clf_p_after]
R 0 0 Add [g_source, pname_start] pname_ptr
R 0 0 Call [sym_intern, pname_ptr, plen] param_sym
R 0 0 Lt [param_sym, 0] bad_p
R 0 0 Jz [bad_p, clf_p_save]
R 0 0 Jmp [clf_p_after]
R 0 0 Label [clf_p_save]
R 0 0 Add [param_base, param_count] slot_idx
R 0 0 Mul [slot_idx, 8] slot_off
R 0 0 StoreI64 [function_params, slot_off, param_sym]
R 0 0 Add [param_count, 1] param_count
R 0 0 Label [clf_p_after]
# skip ',' or ws to ']'
R 0 0 Label [clf_p_seploop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, clf_p_loop]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] is_cl
R 0 0 Jz [is_cl, clf_p_chk_comma]
R 0 0 Jmp [clf_p_loop]
R 0 0 Label [clf_p_chk_comma]
R 0 0 Eq [cc, 44] is_c
R 0 0 Jz [is_c, clf_p_chk_sp]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_loop]
R 0 0 Label [clf_p_chk_sp]
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, clf_p_chk_tt]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_seploop]
R 0 0 Label [clf_p_chk_tt]
R 0 0 Eq [cc, 9] s
R 0 0 Jz [s, clf_p_loop]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [clf_p_seploop]
R 0 0 Label [clf_p_emit]
R 0 0 Label [clf_emit_jmp]
R 0 0 Mul [slot, 8] slot_o
R 0 0 StoreI64 [function_param_count, slot_o, param_count]
# Emit OP_JMP placeholder + reservar fixup
R 0 0 Call [bc_emit, 8]
R 0 0 Add [g_bytecode_len, 0] pending_fn_jmp_pos
R 0 0 Add [slot, 0] pending_fn_slot
R 0 0 Call [bc_emit, 0]
R 0 0 Call [bc_emit, 0]
R 0 0 StoreI64 [function_offsets, slot_o, g_bytecode_len]
# Auto-pop ret_addr a slot UNICO de F (Sub-B). Lote 4: ret_addr_slot >= 256 puede ocurrir
R 0 0 Call [bc_emit, 7]
R 0 0 Add [c_RET_ADDR_BASE, slot] ret_addr_slot
R 0 0 Call [bc_emit_slot, ret_addr_slot]
# Auto-pop params en orden inverso (Sub-A)
R 0 0 Lt [0, param_count] hp
R 0 0 Jz [hp, clf_done_pop]
R 0 0 Sub [param_count, 1] i
R 0 0 Label [clf_pop_loop]
R 0 0 Lt [i, 0] done
R 0 0 Jz [done, clf_do_pop]
R 0 0 Jmp [clf_done_pop]
R 0 0 Label [clf_do_pop]
R 0 0 Add [param_base, i] sl_idx
R 0 0 Mul [sl_idx, 8] sl_off
R 0 0 LoadI64 [function_params, sl_off] psym
R 0 0 Call [bc_emit, 7]
R 0 0 Call [bc_emit_slot, psym]
R 0 0 Sub [i, 1] i
R 0 0 Jmp [clf_pop_loop]
R 0 0 Label [clf_done_pop]
R 0 0 Label [clf_skip]
R 0 0 Call [skip_to_eol, end]
R 0 0 Ret [0]
R 0 0 EndF

# ============================================================================
# F.10 m_parser_r - compile_line_R (paralelo compilador_777.c 1238-1849)
# ============================================================================
# Procesa "R <id> <id> <kind> [args] [output]\n". Maneja Label, Jmp, Jz,
# ExitTop, Call, Ret, EndF como kinds especiales; resto via opcode_from_kind.
# Diseno: helpers handle_* definidos ANTES de compile_line_R (M2-Planet
# style: no forward decl). compile_line_R hace dispatch.

D 0 0 c_kind_Label Text "Label\0"
D 0 0 c_kind_Jmp Text "Jmp\0"
D 0 0 c_kind_Jz Text "Jz\0"
D 0 0 c_kind_ExitTop Text "ExitTop\0"
D 0 0 c_kind_Call Text "Call\0"
D 0 0 c_kind_Ret Text "Ret\0"
D 0 0 c_kind_EndF Text "EndF\0"

# Skip ws+tab desde parse_pos hasta line_end.
F 0 0 clr_skip_ws [line_end]
R 0 0 Label [csw_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, csw_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s1
R 0 0 Jz [s1, csw_chk_t]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [csw_loop]
R 0 0 Label [csw_chk_t]
R 0 0 Eq [cc, 9] s2
R 0 0 Jz [s2, csw_done]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [csw_loop]
R 0 0 Label [csw_done]
R 0 0 Ret []
R 0 0 EndF

# Parse 1 arg hasta delim (espacio/tab/coma/']'). Setea g_tok_off/g_tok_len.
F 0 0 clr_parse_arg_token [line_end]
R 0 0 Add [parse_pos, 0] start
R 0 0 Label [cpa_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, cpa_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s1
R 0 0 Jz [s1, cpa_t]
R 0 0 Jmp [cpa_done]
R 0 0 Label [cpa_t]
R 0 0 Eq [cc, 9] s2
R 0 0 Jz [s2, cpa_co]
R 0 0 Jmp [cpa_done]
R 0 0 Label [cpa_co]
R 0 0 Eq [cc, 44] s3
R 0 0 Jz [s3, cpa_cl]
R 0 0 Jmp [cpa_done]
R 0 0 Label [cpa_cl]
R 0 0 Eq [cc, 93] s4
R 0 0 Jz [s4, cpa_adv]
R 0 0 Jmp [cpa_done]
R 0 0 Label [cpa_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [cpa_loop]
R 0 0 Label [cpa_done]
R 0 0 Add [start, 0] g_tok_off
R 0 0 Sub [parse_pos, start] g_tok_len
R 0 0 Ret []
R 0 0 EndF

# Handler R Label [name]
F 0 0 clr_handle_Label [end, line_end]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] in_line
R 0 0 Jz [in_line, hl_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, hl_done]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Add [parse_pos, 0] lbl_start
R 0 0 Label [hl_nloop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hl_nend]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] s1
R 0 0 Jz [s1, hl_t]
R 0 0 Jmp [hl_nend]
R 0 0 Label [hl_t]
R 0 0 Eq [cc, 32] s2
R 0 0 Jz [s2, hl_tt]
R 0 0 Jmp [hl_nend]
R 0 0 Label [hl_tt]
R 0 0 Eq [cc, 9] s3
R 0 0 Jz [s3, hl_adv]
R 0 0 Jmp [hl_nend]
R 0 0 Label [hl_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hl_nloop]
R 0 0 Label [hl_nend]
R 0 0 Sub [parse_pos, lbl_start] lbl_len
R 0 0 Lt [0, lbl_len] valid
R 0 0 Jz [valid, hl_done]
R 0 0 Add [g_source, lbl_start] lbl_ptr
R 0 0 Call [label_lookup_or_create, lbl_ptr, lbl_len] lbl_slot
R 0 0 Lt [lbl_slot, 0] bad
R 0 0 Jz [bad, hl_set]
R 0 0 Jmp [hl_done]
R 0 0 Label [hl_set]
R 0 0 Mul [lbl_slot, 8] sl_off
R 0 0 StoreI64 [label_offsets, sl_off, g_bytecode_len]
R 0 0 Label [hl_done]
R 0 0 Ret []
R 0 0 EndF

# Handler R Jmp [rel|name]
F 0 0 clr_handle_Jmp [end, line_end]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] in_line
R 0 0 Jz [in_line, hj_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, hj_done]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Add [parse_pos, 0] arg_start
R 0 0 Label [hj_aloop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hj_aend]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] s1
R 0 0 Jz [s1, hj_t]
R 0 0 Jmp [hj_aend]
R 0 0 Label [hj_t]
R 0 0 Eq [cc, 32] s2
R 0 0 Jz [s2, hj_adv]
R 0 0 Jmp [hj_aend]
R 0 0 Label [hj_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hj_aloop]
R 0 0 Label [hj_aend]
R 0 0 Sub [parse_pos, arg_start] alen
R 0 0 Call [parse_i64_at, arg_start, alen] rel
R 0 0 Call [bc_emit, 8]
R 0 0 Eq [g_parse_err, 0] ok
R 0 0 Jz [ok, hj_label]
R 0 0 BitAnd [rel, 255] rb0
R 0 0 Call [bc_emit, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 Call [bc_emit, rs]
R 0 0 Jmp [hj_done]
R 0 0 Label [hj_label]
R 0 0 Add [g_source, arg_start] aptr
R 0 0 Call [label_lookup_or_create, aptr, alen] lsl
R 0 0 Lt [lsl, 0] bad
R 0 0 Jz [bad, hj_lok]
R 0 0 Jmp [hj_done]
R 0 0 Label [hj_lok]
R 0 0 Mul [lsl, 8] loff
R 0 0 LoadI64 [label_offsets, loff] toff
R 0 0 Lt [toff, 0] undef
R 0 0 Jz [undef, hj_resolve]
R 0 0 Call [label_add_fixup, g_bytecode_len, lsl] _
R 0 0 Call [bc_emit, 0]
R 0 0 Call [bc_emit, 0]
R 0 0 Jmp [hj_done]
R 0 0 Label [hj_resolve]
R 0 0 Add [g_bytecode_len, 2] post
R 0 0 Sub [toff, post] rel
R 0 0 BitAnd [rel, 255] rb0
R 0 0 Call [bc_emit, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 Call [bc_emit, rs]
R 0 0 Label [hj_done]
R 0 0 Ret []
R 0 0 EndF

# Handler R Jz [cond, rel|name]
F 0 0 clr_handle_Jz [end, line_end]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] in_line
R 0 0 Jz [in_line, hz_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, hz_done]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [clr_skip_ws, line_end]
# arg1: cond hasta ','
R 0 0 Add [parse_pos, 0] a1_start
R 0 0 Label [hz_a1l]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hz_a1e]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 44] cm
R 0 0 Jz [cm, hz_chk_sp]
R 0 0 Jmp [hz_a1e]
R 0 0 Label [hz_chk_sp]
R 0 0 Eq [cc, 32] sp
R 0 0 Jz [sp, hz_adv1]
R 0 0 Jmp [hz_a1e]
R 0 0 Label [hz_adv1]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hz_a1l]
R 0 0 Label [hz_a1e]
R 0 0 Sub [parse_pos, a1_start] a1_len
R 0 0 Call [emit_load_arg_at, a1_start, a1_len] er
R 0 0 Eq [er, 0] ok
R 0 0 Jz [ok, hz_done]
# skip ws+coma
R 0 0 Label [hz_sep]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hz_a2]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 44] is_c
R 0 0 Jz [is_c, hz_chk_ws]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hz_a2]
R 0 0 Label [hz_chk_ws]
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, hz_chk_t]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hz_sep]
R 0 0 Label [hz_chk_t]
R 0 0 Eq [cc, 9] s
R 0 0 Jz [s, hz_a2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hz_sep]
R 0 0 Label [hz_a2]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Add [parse_pos, 0] a2_start
R 0 0 Label [hz_a2l]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hz_a2e]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] s1
R 0 0 Jz [s1, hz_t2]
R 0 0 Jmp [hz_a2e]
R 0 0 Label [hz_t2]
R 0 0 Eq [cc, 32] s2
R 0 0 Jz [s2, hz_adv2]
R 0 0 Jmp [hz_a2e]
R 0 0 Label [hz_adv2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hz_a2l]
R 0 0 Label [hz_a2e]
R 0 0 Sub [parse_pos, a2_start] a2_len
R 0 0 Call [parse_i64_at, a2_start, a2_len] rel
R 0 0 Call [bc_emit, 9]
R 0 0 Eq [g_parse_err, 0] ok
R 0 0 Jz [ok, hz_label]
R 0 0 BitAnd [rel, 255] rb0
R 0 0 Call [bc_emit, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 Call [bc_emit, rs]
R 0 0 Jmp [hz_done]
R 0 0 Label [hz_label]
R 0 0 Add [g_source, a2_start] aptr
R 0 0 Call [label_lookup_or_create, aptr, a2_len] lsl
R 0 0 Lt [lsl, 0] bad
R 0 0 Jz [bad, hz_lok]
R 0 0 Jmp [hz_done]
R 0 0 Label [hz_lok]
R 0 0 Mul [lsl, 8] loff
R 0 0 LoadI64 [label_offsets, loff] toff
R 0 0 Lt [toff, 0] undef
R 0 0 Jz [undef, hz_resolve]
R 0 0 Call [label_add_fixup, g_bytecode_len, lsl] _
R 0 0 Call [bc_emit, 0]
R 0 0 Call [bc_emit, 0]
R 0 0 Jmp [hz_done]
R 0 0 Label [hz_resolve]
R 0 0 Add [g_bytecode_len, 2] post
R 0 0 Sub [toff, post] rel
R 0 0 BitAnd [rel, 255] rb0
R 0 0 Call [bc_emit, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 Call [bc_emit, rs]
R 0 0 Label [hz_done]
R 0 0 Ret []
R 0 0 EndF

# Handler R ExitTop [val]
F 0 0 clr_handle_ExitTop [end, line_end]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] in_line
R 0 0 Jz [in_line, het_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, het_done]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Add [parse_pos, 0] arg_start
R 0 0 Label [het_aloop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, het_aend]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] s1
R 0 0 Jz [s1, het_t]
R 0 0 Jmp [het_aend]
R 0 0 Label [het_t]
R 0 0 Eq [cc, 32] s2
R 0 0 Jz [s2, het_adv]
R 0 0 Jmp [het_aend]
R 0 0 Label [het_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [het_aloop]
R 0 0 Label [het_aend]
R 0 0 Sub [parse_pos, arg_start] alen
R 0 0 Call [emit_load_arg_at, arg_start, alen] er
R 0 0 Eq [er, 0] ok
R 0 0 Jz [ok, het_done]
R 0 0 Call [bc_emit, 19]
R 0 0 Label [het_done]
R 0 0 Ret []
R 0 0 EndF

# Handler R Call [target, args...] result?
F 0 0 clr_handle_Call [end, line_end]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] in_line
R 0 0 Jz [in_line, hc_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, hc_done]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [clr_skip_ws, line_end]
# Parse target
R 0 0 Add [parse_pos, 0] target_start
R 0 0 Label [hc_tloop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hc_tend]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] s1
R 0 0 Jz [s1, hc_chk_s]
R 0 0 Jmp [hc_tend]
R 0 0 Label [hc_chk_s]
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, hc_chk_t]
R 0 0 Jmp [hc_tend]
R 0 0 Label [hc_chk_t]
R 0 0 Eq [cc, 9] s
R 0 0 Jz [s, hc_chk_co]
R 0 0 Jmp [hc_tend]
R 0 0 Label [hc_chk_co]
R 0 0 Eq [cc, 44] s
R 0 0 Jz [s, hc_t_adv]
R 0 0 Jmp [hc_tend]
R 0 0 Label [hc_t_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_tloop]
R 0 0 Label [hc_tend]
R 0 0 Sub [parse_pos, target_start] target_len
R 0 0 Lt [0, target_len] tval
R 0 0 Jz [tval, hc_done]
# Loop args
R 0 0 Label [hc_args_loop]
R 0 0 Label [hc_args_sep]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hc_emit_call]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] is_close
R 0 0 Jz [is_close, hc_chk_s2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_emit_call]
R 0 0 Label [hc_chk_s2]
R 0 0 Eq [cc, 32] is_s
R 0 0 Jz [is_s, hc_chk_t2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_args_sep]
R 0 0 Label [hc_chk_t2]
R 0 0 Eq [cc, 9] is_t
R 0 0 Jz [is_t, hc_chk_co2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_args_sep]
R 0 0 Label [hc_chk_co2]
R 0 0 Eq [cc, 44] is_co
R 0 0 Jz [is_co, hc_parse_arg]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_args_sep]
R 0 0 Label [hc_parse_arg]
R 0 0 Add [parse_pos, 0] arg_start
R 0 0 Label [hc_aloop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hc_aend]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, hc_a_t]
R 0 0 Jmp [hc_aend]
R 0 0 Label [hc_a_t]
R 0 0 Eq [cc, 9] s
R 0 0 Jz [s, hc_a_co]
R 0 0 Jmp [hc_aend]
R 0 0 Label [hc_a_co]
R 0 0 Eq [cc, 44] s
R 0 0 Jz [s, hc_a_cl]
R 0 0 Jmp [hc_aend]
R 0 0 Label [hc_a_cl]
R 0 0 Eq [cc, 93] s
R 0 0 Jz [s, hc_a_adv]
R 0 0 Jmp [hc_aend]
R 0 0 Label [hc_a_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_aloop]
R 0 0 Label [hc_aend]
R 0 0 Sub [parse_pos, arg_start] arg_len
R 0 0 Lt [0, arg_len] avalid
R 0 0 Jz [avalid, hc_args_sep]
R 0 0 Call [emit_load_arg_at, arg_start, arg_len] er
R 0 0 Eq [er, 0] ok
R 0 0 Jz [ok, hc_done]
R 0 0 Jmp [hc_args_sep]
R 0 0 Label [hc_emit_call]
# Emit OP_CALL + rel
R 0 0 Call [parse_i64_at, target_start, target_len] rel_v
R 0 0 Call [bc_emit, 29]
R 0 0 Eq [g_parse_err, 0] ok
R 0 0 Jz [ok, hc_id_target]
R 0 0 BitAnd [rel_v, 255] rb0
R 0 0 Call [bc_emit, rb0]
R 0 0 Shr [rel_v, 8] rs
R 0 0 Call [bc_emit, rs]
R 0 0 Jmp [hc_done]
R 0 0 Label [hc_id_target]
R 0 0 Add [g_source, target_start] tptr
R 0 0 Call [func_lookup_or_create, tptr, target_len] call_slot
R 0 0 Lt [call_slot, 0] bad
