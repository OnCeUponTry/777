R 0 0 Eq [idx, 19] r
R 0 0 Ret [r]
R 0 0 EndF

# Sizes y ptrs: via tablas arch_handler_offsets / arch_handler_sizes_tbl.
F 0 0 arch_handler_size [idx]
R 0 0 Mul [idx, 8] off
R 0 0 LoadI64 [arch_handler_sizes_tbl, off] sz
R 0 0 Ret [sz]
R 0 0 EndF

# arch_handler_ptr en C retorna int* (puntero). En .777m equivalente: retornamos
# ABS_ADDR = arch_all_handlers + offset (suma puntero base + offset). Caller usa
# LoadByte [ptr_returned, byte_idx] para leer bytes individuales.
F 0 0 arch_handler_ptr [idx]
R 0 0 Mul [idx, 8] off
R 0 0 LoadI64 [arch_handler_offsets, off] handler_off
R 0 0 Add [arch_all_handlers, handler_off] ptr
R 0 0 Ret [ptr]
R 0 0 EndF

# Emit prologo en g_elf at off: xor r12,r12; lea r15,[rip+bc_disp]; lea rbp,[rip+vars_disp]
F 0 0 arch_emit_setup [base, bc_disp, vars_disp]
R 0 0 Call [elf_emit_at, base, 77]
R 0 0 Add [base, 1] p
R 0 0 Call [elf_emit_at, p, 49]
R 0 0 Add [base, 2] p
R 0 0 Call [elf_emit_at, p, 228]
R 0 0 Add [base, 3] p
R 0 0 Call [elf_emit_at, p, 76]
R 0 0 Add [base, 4] p
R 0 0 Call [elf_emit_at, p, 141]
R 0 0 Add [base, 5] p
R 0 0 Call [elf_emit_at, p, 61]
R 0 0 Add [base, 6] p
R 0 0 Call [elf_emit_u32_at, p, bc_disp]
R 0 0 Add [base, 10] p
R 0 0 Call [elf_emit_at, p, 72]
R 0 0 Add [base, 11] p
R 0 0 Call [elf_emit_at, p, 141]
R 0 0 Add [base, 12] p
R 0 0 Call [elf_emit_at, p, 45]
R 0 0 Add [base, 13] p
R 0 0 Call [elf_emit_u32_at, p, vars_disp]
R 0 0 Ret []
R 0 0 EndF

# Emit dispatch loop en g_elf at off
F 0 0 arch_emit_dispatch [base, jt_disp]
R 0 0 Call [elf_emit_at, base, 73]
R 0 0 Add [base, 1] p
R 0 0 Call [elf_emit_at, p, 15]
