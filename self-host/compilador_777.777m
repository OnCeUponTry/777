R 0 0 Shr [rel, 8] rs
R 0 0 BitAnd [rs, 255] rb1
R 0 0 Add [pending_fn_jmp_pos, 1] pos1
R 0 0 StoreByte [g_bytecode, pos1, rb1]
R 0 0 Add [-1, 0] pending_fn_jmp_pos
R 0 0 Label [hef_reset_slot]
R 0 0 Add [-1, 0] pending_fn_slot
# Sub-C reciclaje: restaurar sym_count para liberar slots locales del F cerrado.
R 0 0 Lt [0, fn_slot_alloc_start] has_snap
R 0 0 Jz [has_snap, hef_no_recycle]
R 0 0 Add [fn_slot_alloc_start, 0] sym_count
R 0 0 Add [0, 0] fn_slot_alloc_start
R 0 0 Label [hef_no_recycle]
R 0 0 Ret []
R 0 0 EndF

# Handler generic kind: parse [args] + emit + output_var
F 0 0 clr_handle_generic [end, line_end, op]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] in_line
R 0 0 Jz [in_line, hg_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 91] is_open
R 0 0 Jz [is_open, hg_done]
R 0 0 Add [parse_pos, 1] parse_pos
# Loop args
R 0 0 Label [hg_loop]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hg_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 93] is_close
R 0 0 Jz [is_close, hg_parse]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hg_emit_op]
R 0 0 Label [hg_parse]
R 0 0 Add [parse_pos, 0] arg_start
R 0 0 Label [hg_atok]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hg_aend]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 44] s
R 0 0 Jz [s, hg_chk_cl]
R 0 0 Jmp [hg_aend]
R 0 0 Label [hg_chk_cl]
R 0 0 Eq [cc, 93] s
R 0 0 Jz [s, hg_chk_sp]
R 0 0 Jmp [hg_aend]
R 0 0 Label [hg_chk_sp]
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, hg_aadv]
R 0 0 Jmp [hg_aend]
R 0 0 Label [hg_aadv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hg_atok]
R 0 0 Label [hg_aend]
R 0 0 Sub [parse_pos, arg_start] alen
R 0 0 Call [emit_load_arg_at, arg_start, alen] er
R 0 0 Eq [er, 0] ok
R 0 0 Jz [ok, hg_done]
R 0 0 Label [hg_sep]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hg_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 44] is_co
R 0 0 Jz [is_co, hg_chk_cl2]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hg_loop]
R 0 0 Label [hg_chk_cl2]
R 0 0 Eq [cc, 93] is_cl
R 0 0 Jz [is_cl, hg_chk_ws]
R 0 0 Jmp [hg_loop]
R 0 0 Label [hg_chk_ws]
R 0 0 Eq [cc, 32] s
R 0 0 Jz [s, hg_chk_t]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hg_sep]
R 0 0 Label [hg_chk_t]
R 0 0 Eq [cc, 9] s
R 0 0 Jz [s, hg_loop]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hg_sep]
R 0 0 Label [hg_emit_op]
R 0 0 Call [bc_emit, op]
# output_var if not void kind
R 0 0 Call [is_void_kind, op] is_void
R 0 0 Jz [is_void, hg_out]
R 0 0 Jmp [hg_done]
R 0 0 Label [hg_out]
R 0 0 Call [next_token, line_end]
R 0 0 Add [g_tok_off, 0] o_off
R 0 0 Add [g_tok_len, 0] o_len
R 0 0 Call [is_valid_ident_at, o_off, o_len] is_id
R 0 0 Jz [is_id, hg_addr12]
R 0 0 Add [g_source, o_off] optr
R 0 0 Call [sym_intern, optr, o_len] oslot
R 0 0 Lt [oslot, 0] bad
R 0 0 Jz [bad, hg_emit_st]
R 0 0 Jmp [hg_addr12]
R 0 0 Label [hg_emit_st]
R 0 0 Call [bc_emit, 7]
R 0 0 Call [bc_emit_slot, oslot]
R 0 0 Jmp [hg_done]
R 0 0 Label [hg_addr12]
R 0 0 Call [bc_emit, 5]
R 0 0 Label [hg_done]
R 0 0 Ret []
R 0 0 EndF

# compile_line_R: dispatch a clr_handle_* segun kind.
F 0 0 compile_line_R [end]
R 0 0 Add [parse_pos, 0] line_end
R 0 0 Label [clr_eol]
R 0 0 Lt [line_end, end] cond
R 0 0 Jz [cond, clr_eold]
R 0 0 LoadByte [g_source, line_end] cc
R 0 0 Eq [cc, 10] is_nl
R 0 0 Jz [is_nl, clr_eol_inc]
R 0 0 Jmp [clr_eold]
R 0 0 Label [clr_eol_inc]
R 0 0 Add [line_end, 1] line_end
R 0 0 Jmp [clr_eol]
R 0 0 Label [clr_eold]
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, clr_tok2]
R 0 0 Jmp [clr_skip]
R 0 0 Label [clr_tok2]
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, clr_tok3]
R 0 0 Jmp [clr_skip]
R 0 0 Label [clr_tok3]
R 0 0 Call [next_token, line_end]
R 0 0 Eq [g_tok_len, 0] empty
R 0 0 Jz [empty, clr_disp]
R 0 0 Jmp [clr_skip]
R 0 0 Label [clr_disp]
R 0 0 Add [g_tok_off, 0] kind_off
R 0 0 Add [g_tok_len, 0] klen
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_Label] m
R 0 0 Jz [m, clr_chk_Jmp]
R 0 0 Call [clr_handle_Label, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_chk_Jmp]
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_Jmp] m
R 0 0 Jz [m, clr_chk_Jz]
R 0 0 Call [clr_handle_Jmp, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_chk_Jz]
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_Jz] m
R 0 0 Jz [m, clr_chk_ExitTop]
R 0 0 Call [clr_handle_Jz, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_chk_ExitTop]
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_ExitTop] m
R 0 0 Jz [m, clr_chk_Call]
R 0 0 Call [clr_handle_ExitTop, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_chk_Call]
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_Call] m
R 0 0 Jz [m, clr_chk_Ret]
R 0 0 Call [clr_handle_Call, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_chk_Ret]
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_Ret] m
R 0 0 Jz [m, clr_chk_EndF]
R 0 0 Call [clr_handle_Ret, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_chk_EndF]
R 0 0 Call [eq_str_lit, kind_off, klen, c_kind_EndF] m
R 0 0 Jz [m, clr_generic]
R 0 0 Call [clr_handle_EndF, end, line_end]
R 0 0 Jmp [clr_end]
R 0 0 Label [clr_generic]
R 0 0 Call [opcode_from_kind_at, kind_off, klen] op
R 0 0 Lt [op, 0] bad
R 0 0 Jz [bad, clr_gen_ok]
R 0 0 Jmp [clr_skip]
R 0 0 Label [clr_gen_ok]
R 0 0 Call [clr_handle_generic, end, line_end, op]
R 0 0 Label [clr_end]
R 0 0 Call [skip_to_eol, end]
R 0 0 Ret [0]
R 0 0 Label [clr_skip]
R 0 0 Call [skip_to_eol, end]
R 0 0 Ret [0]
R 0 0 EndF

# ============================================================================
# F.13 m_main - orchestrator + main (paralelo compilador_777.c 2049-2202)
# ============================================================================

# compile_777m_to_bytecode: loop principal de parsing.
F 0 0 compile_777m_to_bytecode []
R 0 0 Add [0, 0] g_bytecode_len
R 0 0 Add [0, 0] parse_pos
R 0 0 Label [c777_loop]
R 0 0 Label [c777_skip_ws]
R 0 0 Lt [parse_pos, g_source_len] cond
R 0 0 Jz [cond, c777_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] is_sp
R 0 0 Jz [is_sp, c777_chk_t]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [c777_skip_ws]
R 0 0 Label [c777_chk_t]
R 0 0 Eq [cc, 9] is_t
R 0 0 Jz [is_t, c777_chk_n]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [c777_skip_ws]
R 0 0 Label [c777_chk_n]
R 0 0 Eq [cc, 10] is_n
R 0 0 Jz [is_n, c777_chk_r]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [c777_skip_ws]
R 0 0 Label [c777_chk_r]
R 0 0 Eq [cc, 13] is_r
R 0 0 Jz [is_r, c777_dispatch]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [c777_skip_ws]
R 0 0 Label [c777_dispatch]
R 0 0 Lt [parse_pos, g_source_len] cond
R 0 0 Jz [cond, c777_done]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 55] is_7
R 0 0 Jz [is_7, c777_chk_F]
R 0 0 Call [skip_to_eol, g_source_len]
R 0 0 Jmp [c777_loop]
R 0 0 Label [c777_chk_F]
R 0 0 Eq [cc, 70] is_F
R 0 0 Jz [is_F, c777_chk_C]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [compile_line_F, g_source_len]
R 0 0 Jmp [c777_loop]
R 0 0 Label [c777_chk_C]
R 0 0 Eq [cc, 67] is_C
R 0 0 Jz [is_C, c777_chk_D]
R 0 0 Call [skip_to_eol, g_source_len]
R 0 0 Jmp [c777_loop]
R 0 0 Label [c777_chk_D]
R 0 0 Eq [cc, 68] is_D
R 0 0 Jz [is_D, c777_chk_R]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [compile_line_D, g_source_len]
R 0 0 Jmp [c777_loop]
R 0 0 Label [c777_chk_R]
R 0 0 Eq [cc, 82] is_R
R 0 0 Jz [is_R, c777_other]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Call [compile_line_R, g_source_len]
R 0 0 Jmp [c777_loop]
R 0 0 Label [c777_other]
R 0 0 Call [skip_to_eol, g_source_len]
R 0 0 Jmp [c777_loop]
R 0 0 Label [c777_done]
# Fallback EOF Sub-G: patch pending F si abierta
R 0 0 Lt [pending_fn_jmp_pos, 0] no_pending
R 0 0 Jz [no_pending, c777_eof_patch]
R 0 0 Jmp [c777_after_eof]
R 0 0 Label [c777_eof_patch]
R 0 0 Add [pending_fn_jmp_pos, 2] post
R 0 0 Sub [g_bytecode_len, post] rel
R 0 0 BitAnd [rel, 255] rb0
R 0 0 StoreByte [g_bytecode, pending_fn_jmp_pos, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 BitAnd [rs, 255] rb1
R 0 0 Add [pending_fn_jmp_pos, 1] pos1
R 0 0 StoreByte [g_bytecode, pos1, rb1]
R 0 0 Add [-1, 0] pending_fn_jmp_pos
R 0 0 Label [c777_after_eof]
R 0 0 Add [-1, 0] pending_fn_slot
# Sub-C reciclaje EOF: restaurar sym_count tras cerrar F final.
R 0 0 Lt [0, fn_slot_alloc_start] has_snap_eof
R 0 0 Jz [has_snap_eof, c777_no_recycle]
R 0 0 Add [fn_slot_alloc_start, 0] sym_count
R 0 0 Add [0, 0] fn_slot_alloc_start
R 0 0 Label [c777_no_recycle]
# Resolve fixups + emit HALT + append str_data
R 0 0 Call [func_resolve_fixups]
R 0 0 Call [label_resolve_fixups]
R 0 0 Call [bc_emit, 0]
# Append str_data + patch fixups con abs addr
R 0 0 Lt [0, str_data_len] hasstr
R 0 0 Jz [hasstr, c777_no_str]
R 0 0 Add [g_bytecode_len, 0] bc_data_start
# scaffold_size = setup + dispatch + sum(handler) + tail + jt + vars
R 0 0 Call [arch_setup_size] ss
R 0 0 Call [arch_dispatch_size] ds
R 0 0 Call [arch_tail_size] ts
R 0 0 Call [arch_jt_entry_bytes] jte
R 0 0 Call [arch_jmp_back_size] jbs
R 0 0 Add [ss, ds] scaffold
R 0 0 Add [0, 0] i
R 0 0 Label [sc_loop]
R 0 0 Lt [i, c_NUM_OPCODES] cond
R 0 0 Jz [cond, sc_done]
R 0 0 Call [arch_handler_size, i] hsz
R 0 0 Call [arch_handler_is_halt, i] is_h
R 0 0 Jz [is_h, sc_chk_e]
R 0 0 Add [scaffold, jbs] scaffold
R 0 0 Jmp [sc_next]
R 0 0 Label [sc_chk_e]
R 0 0 Call [arch_handler_is_exit, i] is_e
R 0 0 Jz [is_e, sc_norm]
R 0 0 Add [scaffold, hsz] scaffold
R 0 0 Jmp [sc_next]
R 0 0 Label [sc_norm]
R 0 0 Add [scaffold, hsz] scaffold
R 0 0 Add [scaffold, jbs] scaffold
R 0 0 Label [sc_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [sc_loop]
R 0 0 Label [sc_done]
R 0 0 Add [scaffold, ts] scaffold
R 0 0 Mul [c_NUM_OPCODES, jte] jts
R 0 0 Add [scaffold, jts] scaffold
R 0 0 Add [scaffold, c_VARS_AREA_SIZE] scaffold
R 0 0 Call [arch_base_vaddr] bva
R 0 0 Add [bva, c_HEADER_TOTAL] tmp1
R 0 0 Add [tmp1, scaffold] bc_section_abs
# patch fixups
R 0 0 Add [0, 0] i
R 0 0 Label [pf_loop]
R 0 0 Lt [i, fixup_count] cond
R 0 0 Jz [cond, pf_done]
R 0 0 Mul [i, 8] fioff
R 0 0 LoadI64 [fixup_data, fioff] doff
R 0 0 LoadI64 [fixup_bc, fioff] fpos
R 0 0 Add [bc_section_abs, bc_data_start] tmp2
R 0 0 Add [tmp2, doff] abs_addr
R 0 0 BitAnd [abs_addr, 255] b0
R 0 0 StoreByte [g_bytecode, fpos, b0]
R 0 0 Shr [abs_addr, 8] s1
R 0 0 BitAnd [s1, 255] b1
R 0 0 Add [fpos, 1] p1
R 0 0 StoreByte [g_bytecode, p1, b1]
R 0 0 Shr [abs_addr, 16] s2
R 0 0 BitAnd [s2, 255] b2
R 0 0 Add [fpos, 2] p2
R 0 0 StoreByte [g_bytecode, p2, b2]
R 0 0 Shr [abs_addr, 24] s3
R 0 0 BitAnd [s3, 255] b3
R 0 0 Add [fpos, 3] p3
R 0 0 StoreByte [g_bytecode, p3, b3]
R 0 0 Shr [abs_addr, 32] s4
R 0 0 BitAnd [s4, 255] b4
R 0 0 Add [fpos, 4] p4
R 0 0 StoreByte [g_bytecode, p4, b4]
R 0 0 Shr [abs_addr, 40] s5
R 0 0 BitAnd [s5, 255] b5
R 0 0 Add [fpos, 5] p5
R 0 0 StoreByte [g_bytecode, p5, b5]
R 0 0 Shr [abs_addr, 48] s6
R 0 0 BitAnd [s6, 255] b6
R 0 0 Add [fpos, 6] p6
R 0 0 StoreByte [g_bytecode, p6, b6]
R 0 0 Shr [abs_addr, 56] s7
R 0 0 BitAnd [s7, 255] b7
R 0 0 Add [fpos, 7] p7
R 0 0 StoreByte [g_bytecode, p7, b7]
R 0 0 Add [i, 1] i
R 0 0 Jmp [pf_loop]
R 0 0 Label [pf_done]
# Append str_data to g_bytecode
R 0 0 Add [0, 0] j
R 0 0 Label [as_loop]
R 0 0 Lt [j, str_data_len] cond
R 0 0 Jz [cond, c777_no_str]
R 0 0 LoadByte [str_data, j] b
R 0 0 StoreByte [g_bytecode, g_bytecode_len, b]
R 0 0 Add [g_bytecode_len, 1] g_bytecode_len
R 0 0 Add [j, 1] j
R 0 0 Jmp [as_loop]
R 0 0 Label [c777_no_str]
R 0 0 Ret []
R 0 0 EndF

# main: init + read stdin + compile + build_vm_elf + write stdout
F 0 0 main []
R 0 0 Call [sym_init]
R 0 0 Call [str_init]
R 0 0 Call [func_init]
R 0 0 Call [label_init]
R 0 0 Call [arch_init]
R 0 0 Add [0, 0] g_source_len
R 0 0 Label [main_read]
R 0 0 Sub [c_MAX_SOURCE, g_source_len] avail
R 0 0 Lt [0, avail] hasspace
R 0 0 Jz [hasspace, main_compile]
R 0 0 Add [g_source, g_source_len] dst
R 0 0 FdRead [c_FD_STDIN, dst, avail] n
R 0 0 Lt [n, 1] eof
R 0 0 Jz [eof, main_read_more]
R 0 0 Jmp [main_compile]
R 0 0 Label [main_read_more]
R 0 0 Add [g_source_len, n] g_source_len
R 0 0 Jmp [main_read]
R 0 0 Label [main_compile]
R 0 0 Call [compile_777m_to_bytecode]
R 0 0 Call [build_vm_elf]
R 0 0 FdWrite [c_FD_STDOUT, g_elf, g_elf_len] w
R 0 0 Ret []
R 0 0 EndF

# Entry point: llama main
R 0 0 Call [main]
R 0 0 ExitTop [0]
