R 0 0 Label [hc_r_adv]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [hc_r_loop]
R 0 0 Label [hc_r_end]
R 0 0 Sub [parse_pos, result_start] result_len
R 0 0 Lt [0, result_len] hasres
