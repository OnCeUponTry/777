# ============================================================================
# compilador_777.777m - port real de compilador_777.c a .777m source
# ============================================================================
# Lee source .777m por stdin, emite ELF ejecutable a stdout.
# Equivalente functional de compilador_777.c (~2280 LOC C subset).
#
# Sub-decisiones aplicadas:
#   Sub-A params F + Call args
#   Sub-B Ret val + Call result + DROP
#   Sub-C scope local cells dentro F (vars sin prefix son locales por F)
#   Sub-E labels nombrados con fixup table
#   Sub-G EndF cierre explicito F body (multi-Ret support)
#
# Estructura:
#   F.1 m_const     - constantes + Alloc buffers globales
#   F.2 m_str       - str_intern + str_eq + str_init + str_add_fixup
#   F.3 m_sym       - sym_init + sym_eq + sym_lookup_global + sym_intern_global + sym_intern + is_valid_ident
#   F.4 m_func      - func_init + func_lookup_or_create + func_add_fixup + func_resolve_fixups
#   F.5 m_label     - label_init + label_lookup_or_create + label_add_fixup + label_resolve_fixups
#   F.6 m_helpers   - sb + var_slot + parse_i64 + fits_in_i32 + bc_emit_*
#   F.7 m_arch_x86  - arch_* handlers + emit setup/dispatch/tail
#   F.8 m_elf       - build_vm_elf + elf_emit_*
#   F.9 m_parser_h  - skip_to_eol + eq_str + emit_load_arg + opcode_from_kind + is_void_kind
#   F.10 m_parser_r - compile_line_R (47 kinds)
#   F.11 m_parser_d - compile_line_D + escapes Text
#   F.12 m_parser_f - compile_line_F + params + auto-pop + EndF
#   F.13 m_main     - compile_777m_to_bytecode + main
# ============================================================================

# ============================================================================
# F.1 m_const - constantes y buffers globales
# ============================================================================
# Constantes capacidades del compilador (paralelo a #define del .c).

# DEBUG B9: globals para instrumentar bytecode-level
D 0 0 dbgfd Integer 2
D 0 0 dbg1 Text "1"
D 0 0 dbg2 Text "2"
D 0 0 dbg3 Text "3"
D 0 0 dbg4 Text "4"

D 0 0 c_NUM_OPCODES         Integer 52
D 0 0 c_HEADER_TOTAL        Integer 120
D 0 0 c_DROP_SLOT           Integer 4095
D 0 0 c_RET_ADDR_BASE       Integer 3000
D 0 0 c_USER_SLOTS_MAX      Integer 3000
D 0 0 c_N_VARS              Integer 4096
D 0 0 c_VARS_AREA_SIZE      Integer 32768

D 0 0 c_MAX_SOURCE          Integer 262144
D 0 0 c_MAX_BYTECODE        Integer 131072
D 0 0 c_MAX_ELF             Integer 262144

D 0 0 c_MAX_STR_DATA        Integer 8192
D 0 0 c_MAX_STRINGS         Integer 256
D 0 0 c_MAX_FIXUPS          Integer 256
D 0 0 c_STR_OFFSETS_BYTES   Integer 2048
D 0 0 c_FIXUPS_BYTES        Integer 2048

D 0 0 c_MAX_FUNCTIONS       Integer 128
D 0 0 c_MAX_FUNCTION_FIXUPS Integer 1024
D 0 0 c_MAX_FUNC_NAME_LEN   Integer 32
D 0 0 c_FUNC_NAMES_BYTES    Integer 4096
D 0 0 c_MAX_PARAMS_PER_FN   Integer 8
D 0 0 c_FUNC_PARAMS_BYTES   Integer 8192
D 0 0 c_FUNCTION_OFFSETS_BYTES Integer 1024
D 0 0 c_FUNCTION_FIXUPS_BYTES Integer 8192

D 0 0 c_MAX_LABELS          Integer 512
D 0 0 c_MAX_LABEL_FIXUPS    Integer 1024
D 0 0 c_MAX_LABEL_NAME_LEN  Integer 32
D 0 0 c_LABEL_NAMES_BYTES   Integer 16384
D 0 0 c_LABEL_OFFSETS_BYTES Integer 4096
D 0 0 c_LABEL_FIXUPS_BYTES  Integer 8192

D 0 0 c_MAX_NAME_LEN        Integer 32
D 0 0 c_SYM_BUF_SIZE        Integer 131072

D 0 0 c_FD_STDIN            Integer 0
D 0 0 c_FD_STDOUT           Integer 1
D 0 0 c_FD_STDERR           Integer 2
D 0 0 c_NEG_ONE             Integer -1
D 0 0 c_BYTE_MASK           Integer 255

# Allocs buffers globales (top-level => slots globales accesibles desde F).
R 0 0 Alloc [c_MAX_SOURCE]       g_source
R 0 0 Alloc [c_MAX_BYTECODE]     g_bytecode
R 0 0 Alloc [c_MAX_ELF]          g_elf

D 0 0 g_source_len    Integer 0
D 0 0 g_bytecode_len  Integer 0
D 0 0 g_elf_len       Integer 0

# String table buffers
R 0 0 Alloc [c_MAX_STR_DATA]     str_data
R 0 0 Alloc [c_MAX_STR_DATA]     str_tmp
R 0 0 Alloc [c_STR_OFFSETS_BYTES] str_offsets
R 0 0 Alloc [c_STR_OFFSETS_BYTES] str_lens
R 0 0 Alloc [c_FIXUPS_BYTES]     fixup_bc
R 0 0 Alloc [c_FIXUPS_BYTES]     fixup_data
D 0 0 str_data_len   Integer 0
D 0 0 str_count      Integer 0
D 0 0 fixup_count    Integer 0

# Symbol table buffers
R 0 0 Alloc [c_SYM_BUF_SIZE]     sym_names
D 0 0 sym_count      Integer 0
# Sub-C reciclaje slots: sym_high_water = max sym_count alcanzado.
# Nuevos slots siempre >= sym_high_water (no colision con slots usados por F previos).
D 0 0 sym_high_water Integer 26
# Snapshot sym_count al entrar F. Al salir F: sym_count = fn_slot_alloc_start (libera locales).
D 0 0 fn_slot_alloc_start Integer 0

# Functions table buffers
R 0 0 Alloc [c_FUNC_NAMES_BYTES]      function_names
R 0 0 Alloc [c_FUNCTION_OFFSETS_BYTES] function_offsets
R 0 0 Alloc [c_FUNCTION_OFFSETS_BYTES] function_param_count
R 0 0 Alloc [c_FUNC_PARAMS_BYTES]     function_params
R 0 0 Alloc [c_FUNCTION_FIXUPS_BYTES] function_fixup_bc
R 0 0 Alloc [c_FUNCTION_FIXUPS_BYTES] function_fixup_target
D 0 0 function_count       Integer 0
D 0 0 function_fixup_count Integer 0
D 0 0 pending_fn_jmp_pos   Integer -1
D 0 0 pending_fn_slot      Integer -1

# Labels table buffers
R 0 0 Alloc [c_LABEL_NAMES_BYTES]   label_names
R 0 0 Alloc [c_LABEL_OFFSETS_BYTES] label_offsets
R 0 0 Alloc [c_LABEL_FIXUPS_BYTES]  label_fixup_bc
R 0 0 Alloc [c_LABEL_FIXUPS_BYTES]  label_fixup_target
D 0 0 label_count       Integer 0
D 0 0 label_fixup_count Integer 0

# ============================================================================
# F.2 m_str - string interning + fixups (paralelo a compilador_777.c 204-269)
# ============================================================================

# void str_init() { str_data_len=0; str_count=0; fixup_count=0;
#                   zero out str_data[MAX_STR_DATA]; }
F 0 0 str_init []
R 0 0 Add [0, 0] str_data_len
R 0 0 Add [0, 0] str_count
R 0 0 Add [0, 0] fixup_count
R 0 0 Add [0, 0] i
R 0 0 Label [zo_loop]
R 0 0 Lt [i, c_MAX_STR_DATA] cond
R 0 0 Jz [cond, zo_done]
R 0 0 StoreByte [str_data, i, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [zo_loop]
R 0 0 Label [zo_done]
R 0 0 Ret []
R 0 0 EndF

# int str_eq(int off, int len, char* content, int content_len)
#   { si len!=clen return 0; for i in 0..len: if str_data[off+i]!=content[i] return 0; return 1; }
F 0 0 str_eq [off, len, content, content_len]
R 0 0 Eq [len, content_len] cond
R 0 0 Jz [cond, ne_neq]
R 0 0 Add [0, 0] i
R 0 0 Label [ne_loop]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, ne_done]
R 0 0 Add [off, i] addr_a
R 0 0 LoadByte [str_data, addr_a] b_a
R 0 0 LoadByte [content, i] b_b
R 0 0 Eq [b_a, b_b] cond
R 0 0 Jz [cond, ne_neq]
R 0 0 Add [i, 1] i
R 0 0 Jmp [ne_loop]
R 0 0 Label [ne_done]
R 0 0 Ret [1]
R 0 0 Label [ne_neq]
R 0 0 Ret [0]
R 0 0 EndF

# int str_intern(char* content, int content_len)
#   { busca; si match return offset; sino append y retorna nuevo offset; -1 si full }
F 0 0 str_intern [content, content_len]
R 0 0 Add [0, 0] i
R 0 0 Label [in_lookup]
R 0 0 Lt [i, str_count] cond
R 0 0 Jz [cond, in_no_match]
R 0 0 Mul [i, 8] idx_off
R 0 0 LoadI64 [str_offsets, idx_off] eoff
R 0 0 LoadI64 [str_lens, idx_off] elen
R 0 0 Call [str_eq, eoff, elen, content, content_len] eqr
R 0 0 Jz [eqr, in_next]
R 0 0 Ret [eoff]
R 0 0 Label [in_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [in_lookup]
R 0 0 Label [in_no_match]
R 0 0 Lt [str_count, c_MAX_STRINGS] cond
R 0 0 Jz [cond, in_full]
R 0 0 Add [str_data_len, content_len] would_be
R 0 0 Gt [would_be, c_MAX_STR_DATA] over
R 0 0 Jz [over, in_cap_ok]
R 0 0 Label [in_full]
R 0 0 Ret [-1]
R 0 0 Label [in_cap_ok]
R 0 0 Add [str_data_len, 0] new_off
R 0 0 Add [0, 0] i
R 0 0 Label [in_copy]
R 0 0 Lt [i, content_len] cond
R 0 0 Jz [cond, in_cdone]
R 0 0 Add [new_off, i] dst_off
R 0 0 LoadByte [content, i] b
R 0 0 StoreByte [str_data, dst_off, b]
R 0 0 Add [i, 1] i
R 0 0 Jmp [in_copy]
R 0 0 Label [in_cdone]
R 0 0 Add [str_data_len, content_len] str_data_len
R 0 0 Mul [str_count, 8] slot_off
R 0 0 StoreI64 [str_offsets, slot_off, new_off]
R 0 0 StoreI64 [str_lens, slot_off, content_len]
R 0 0 Add [str_count, 1] str_count
R 0 0 Ret [new_off]
R 0 0 EndF

# int str_add_fixup(int bc_pos, int data_off)
#   { si fixup_count >= MAX return 1; append; return 0 }
F 0 0 str_add_fixup [bc_pos, data_off]
R 0 0 Lt [fixup_count, c_MAX_FIXUPS] cond
R 0 0 Jz [cond, af_full]
R 0 0 Mul [fixup_count, 8] slot_off
R 0 0 StoreI64 [fixup_bc, slot_off, bc_pos]
R 0 0 StoreI64 [fixup_data, slot_off, data_off]
R 0 0 Add [fixup_count, 1] fixup_count
R 0 0 Ret [0]
R 0 0 Label [af_full]
R 0 0 Ret [1]
R 0 0 EndF

# ============================================================================
# F.3 m_sym - symbol table (paralelo a compilador_777.c 494-592)
# ============================================================================
# Layout: sym_names[slot * MAX_NAME_LEN] = nombre, terminado en 0.
# Slots 0-25 prepoblados con 'A'..'Z'. sym_count=26 inicial.

# void sym_init() { zero out sym_names; prepuebla A-Z; sym_count=26 }
F 0 0 sym_init []
R 0 0 Add [0, 0] i
R 0 0 Label [si_zero]
R 0 0 Lt [i, c_SYM_BUF_SIZE] cond
R 0 0 Jz [cond, si_zdone]
R 0 0 StoreByte [sym_names, i, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [si_zero]
R 0 0 Label [si_zdone]
R 0 0 Add [0, 0] i
R 0 0 Label [si_az]
R 0 0 Lt [i, 26] cond
R 0 0 Jz [cond, si_done]
R 0 0 Mul [i, c_MAX_NAME_LEN] base
R 0 0 Add [65, i] ch
R 0 0 StoreByte [sym_names, base, ch]
R 0 0 Add [base, 1] base1
R 0 0 StoreByte [sym_names, base1, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [si_az]
R 0 0 Label [si_done]
R 0 0 Add [26, 0] sym_count
R 0 0 Add [26, 0] sym_high_water
R 0 0 Ret []
R 0 0 EndF

# int sym_eq(int slot, char* name, int len)
#   { compara sym_names[slot*32 .. slot*32+len] con name[0..len] + terminator 0 }
F 0 0 sym_eq [slot, name, len]
R 0 0 Mul [slot, c_MAX_NAME_LEN] base
R 0 0 Add [0, 0] i
R 0 0 Label [se_loop]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, se_post]
R 0 0 Add [base, i] off_a
R 0 0 LoadByte [sym_names, off_a] b_a
R 0 0 LoadByte [name, i] b_b
R 0 0 Eq [b_a, b_b] cond
R 0 0 Jz [cond, se_neq]
R 0 0 Add [i, 1] i
R 0 0 Jmp [se_loop]
R 0 0 Label [se_post]
R 0 0 Add [base, len] term_off
R 0 0 LoadByte [sym_names, term_off] b_t
R 0 0 Eq [b_t, 0] cond
R 0 0 Jz [cond, se_neq]
R 0 0 Ret [1]
R 0 0 Label [se_neq]
R 0 0 Ret [0]
R 0 0 EndF

# int sym_lookup_global(char* name, int len) -> slot o -1
F 0 0 sym_lookup_global [name, len]
R 0 0 Lt [0, len] valid
R 0 0 Jz [valid, sl_invalid]
R 0 0 Sub [c_MAX_NAME_LEN, 1] max_allowed
R 0 0 Gt [len, max_allowed] too_long
R 0 0 Jz [too_long, sl_lenok]
R 0 0 Ret [-1]
R 0 0 Label [sl_lenok]
R 0 0 Add [0, 0] slot
R 0 0 Label [sl_loop]
R 0 0 Lt [slot, sym_count] cond
R 0 0 Jz [cond, sl_notfound]
R 0 0 Call [sym_eq, slot, name, len] eqr
R 0 0 Jz [eqr, sl_next]
R 0 0 Ret [slot]
R 0 0 Label [sl_next]
R 0 0 Add [slot, 1] slot
R 0 0 Jmp [sl_loop]
R 0 0 Label [sl_notfound]
R 0 0 Ret [-1]
R 0 0 Label [sl_invalid]
R 0 0 Ret [-1]
R 0 0 EndF

# int sym_intern_global(char* name, int len) -> slot (crea si no existe)
# Sub-C reciclaje: nuevo slot = max(sym_count, sym_high_water). Eso protege
# slots ya emitidos por F's previos cuya sym_count fue reseteada al cerrar F.
F 0 0 sym_intern_global [name, len]
R 0 0 Call [sym_lookup_global, name, len] existing
R 0 0 Lt [existing, 0] not_found
R 0 0 Jz [not_found, sig_return]
R 0 0 Lt [sym_count, sym_high_water] use_hw
R 0 0 Jz [use_hw, sig_use_count]
R 0 0 Add [sym_high_water, 0] slot
R 0 0 Jmp [sig_check_cap]
R 0 0 Label [sig_use_count]
R 0 0 Add [sym_count, 0] slot
R 0 0 Label [sig_check_cap]
R 0 0 Lt [slot, c_USER_SLOTS_MAX] cap_ok
R 0 0 Jz [cap_ok, sig_full]
R 0 0 Mul [slot, c_MAX_NAME_LEN] base
R 0 0 Add [0, 0] i
R 0 0 Label [sig_copy]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, sig_cdone]
R 0 0 Add [base, i] dst
R 0 0 LoadByte [name, i] b
R 0 0 StoreByte [sym_names, dst, b]
R 0 0 Add [i, 1] i
R 0 0 Jmp [sig_copy]
R 0 0 Label [sig_cdone]
R 0 0 Add [base, len] term
R 0 0 StoreByte [sym_names, term, 0]
R 0 0 Add [slot, 1] sym_count
R 0 0 Gt [sym_count, sym_high_water] grew
R 0 0 Jz [grew, sig_no_hw]
R 0 0 Add [sym_count, 0] sym_high_water
R 0 0 Label [sig_no_hw]
R 0 0 Ret [slot]
R 0 0 Label [sig_return]
R 0 0 Ret [existing]
R 0 0 Label [sig_full]
R 0 0 Ret [-1]
R 0 0 EndF

# Buffer temp para prefijar nombres locales Sub-C: [HI, LO, '|', ...name].
R 0 0 Alloc [c_MAX_NAME_LEN] sym_prefixed_buf

# int sym_intern(char* name, int len) -> slot
# Sub-decision C: dentro F (pending_fn_slot >= 0):
#   - __name: skip __, intern en global directo.
#   - lookup global existente: si existe (vars top-level), retorna.
#   - sino: intern prefijado [HI,LO,'|',name] -> slot local.
# Fuera F: intern global normal.
F 0 0 sym_intern [name, len]
R 0 0 Lt [0, len] valid
R 0 0 Jz [valid, si_inv]
R 0 0 Sub [c_MAX_NAME_LEN, 1] max_allowed
R 0 0 Gt [len, max_allowed] too_long
R 0 0 Jz [too_long, si_lenok]
R 0 0 Ret [-1]
R 0 0 Label [si_lenok]
R 0 0 Lt [pending_fn_slot, 0] outside
R 0 0 Jz [outside, si_inside]
R 0 0 Call [sym_intern_global, name, len] r1
R 0 0 Ret [r1]
R 0 0 Label [si_inside]
R 0 0 Gt [len, 2] longer
R 0 0 Jz [longer, si_try_global]
R 0 0 LoadByte [name, 0] b0
R 0 0 Eq [b0, 95] is_u0
R 0 0 Jz [is_u0, si_try_global]
R 0 0 LoadByte [name, 1] b1
R 0 0 Eq [b1, 95] is_u1
R 0 0 Jz [is_u1, si_try_global]
R 0 0 Add [name, 2] adj_name
R 0 0 Sub [len, 2] adj_len
R 0 0 Call [sym_intern_global, adj_name, adj_len] r2
R 0 0 Ret [r2]
R 0 0 Label [si_try_global]
R 0 0 Call [sym_lookup_global, name, len] eg
R 0 0 Lt [eg, 0] not_global
R 0 0 Jz [not_global, si_use_global]
R 0 0 StoreByte [sym_prefixed_buf, 0, pending_fn_slot]
R 0 0 Shr [pending_fn_slot, 8] hi
R 0 0 StoreByte [sym_prefixed_buf, 1, hi]
R 0 0 StoreByte [sym_prefixed_buf, 2, 124]
R 0 0 Add [0, 0] i
R 0 0 Label [si_pfx]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, si_pdone]
R 0 0 LoadByte [name, i] b
R 0 0 Add [3, i] pdst
R 0 0 StoreByte [sym_prefixed_buf, pdst, b]
R 0 0 Add [i, 1] i
R 0 0 Jmp [si_pfx]
R 0 0 Label [si_pdone]
R 0 0 Add [3, len] plen
R 0 0 Sub [c_MAX_NAME_LEN, 1] max_p
R 0 0 Gt [plen, max_p] over
R 0 0 Jz [over, si_pcall]
R 0 0 Ret [-1]
R 0 0 Label [si_pcall]
R 0 0 Call [sym_intern_global, sym_prefixed_buf, plen] r3
R 0 0 Ret [r3]
R 0 0 Label [si_use_global]
R 0 0 Ret [eg]
R 0 0 Label [si_inv]
R 0 0 Ret [-1]
R 0 0 EndF

# ============================================================================
# F.4 m_func - functions table + fixups (paralelo a compilador_777.c 273-382)
# ============================================================================
# Layout:
#   function_names[slot * MAX_FUNC_NAME_LEN] = name terminado en 0.
#   function_offsets[slot] = i64 offset bytecode (o -1 si no definido aun).
#   function_param_count[slot] = i64 count.
#   function_params[slot * MAX_PARAMS_PER_FN + i] = i64 sym slot del param i.

# void func_init()
F 0 0 func_init []
R 0 0 Add [0, 0] i
R 0 0 Label [fi_zname]
R 0 0 Lt [i, c_FUNC_NAMES_BYTES] cond
R 0 0 Jz [cond, fi_zndone]
R 0 0 StoreByte [function_names, i, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [fi_zname]
R 0 0 Label [fi_zndone]
R 0 0 Add [0, 0] i
R 0 0 Label [fi_zoff]
R 0 0 Lt [i, c_MAX_FUNCTIONS] cond
R 0 0 Jz [cond, fi_zodone]
R 0 0 Mul [i, 8] off
R 0 0 StoreI64 [function_offsets, off, -1]
R 0 0 StoreI64 [function_param_count, off, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [fi_zoff]
R 0 0 Label [fi_zodone]
R 0 0 Add [0, 0] i
R 0 0 Label [fi_zpar]
R 0 0 Lt [i, c_FUNC_PARAMS_BYTES] cond
R 0 0 Jz [cond, fi_zpdone]
R 0 0 StoreByte [function_params, i, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [fi_zpar]
R 0 0 Label [fi_zpdone]
R 0 0 Add [0, 0] function_count
R 0 0 Add [0, 0] function_fixup_count
R 0 0 Add [-1, 0] pending_fn_jmp_pos
R 0 0 Add [-1, 0] pending_fn_slot
R 0 0 Ret []
R 0 0 EndF

# int func_name_eq(int slot, char* name, int len) -> 1 si igual
F 0 0 func_name_eq [slot, name, len]
R 0 0 Mul [slot, c_MAX_FUNC_NAME_LEN] base
R 0 0 Add [0, 0] i
R 0 0 Label [fne_loop]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, fne_post]
R 0 0 Add [base, i] off_a
R 0 0 LoadByte [function_names, off_a] b_a
R 0 0 LoadByte [name, i] b_b
R 0 0 Eq [b_a, b_b] cond
R 0 0 Jz [cond, fne_neq]
R 0 0 Add [i, 1] i
R 0 0 Jmp [fne_loop]
R 0 0 Label [fne_post]
R 0 0 Add [base, len] term_off
R 0 0 LoadByte [function_names, term_off] b_t
R 0 0 Eq [b_t, 0] cond
R 0 0 Jz [cond, fne_neq]
R 0 0 Ret [1]
R 0 0 Label [fne_neq]
R 0 0 Ret [0]
R 0 0 EndF

# int func_lookup_or_create(char* name, int len) -> slot o -1
F 0 0 func_lookup_or_create [name, len]
R 0 0 Lt [0, len] valid
R 0 0 Jz [valid, flc_inv]
R 0 0 Sub [c_MAX_FUNC_NAME_LEN, 1] max_allowed
R 0 0 Gt [len, max_allowed] too_long
R 0 0 Jz [too_long, flc_lenok]
R 0 0 Ret [-1]
R 0 0 Label [flc_lenok]
R 0 0 Add [0, 0] slot
R 0 0 Label [flc_loop]
R 0 0 Lt [slot, function_count] cond
R 0 0 Jz [cond, flc_create]
R 0 0 Call [func_name_eq, slot, name, len] eqr
R 0 0 Jz [eqr, flc_next]
R 0 0 Ret [slot]
R 0 0 Label [flc_next]
R 0 0 Add [slot, 1] slot
R 0 0 Jmp [flc_loop]
R 0 0 Label [flc_create]
R 0 0 Lt [function_count, c_MAX_FUNCTIONS] cap
R 0 0 Jz [cap, flc_full]
R 0 0 Add [function_count, 0] slot
R 0 0 Mul [slot, c_MAX_FUNC_NAME_LEN] base
R 0 0 Add [0, 0] i
R 0 0 Label [flc_copy]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, flc_cdone]
R 0 0 Add [base, i] dst
R 0 0 LoadByte [name, i] b
R 0 0 StoreByte [function_names, dst, b]
R 0 0 Add [i, 1] i
R 0 0 Jmp [flc_copy]
R 0 0 Label [flc_cdone]
R 0 0 Add [base, len] term
R 0 0 StoreByte [function_names, term, 0]
R 0 0 Mul [slot, 8] off_i64
R 0 0 StoreI64 [function_offsets, off_i64, -1]
R 0 0 Add [function_count, 1] function_count
R 0 0 Ret [slot]
R 0 0 Label [flc_full]
R 0 0 Ret [-1]
R 0 0 Label [flc_inv]
R 0 0 Ret [-1]
R 0 0 EndF

# int func_add_fixup(int bc_pos, int target_slot) -> 0 OK / 1 full
F 0 0 func_add_fixup [bc_pos, target_slot]
R 0 0 Lt [function_fixup_count, c_MAX_FUNCTION_FIXUPS] cond
R 0 0 Jz [cond, fafu_full]
R 0 0 Mul [function_fixup_count, 8] off
R 0 0 StoreI64 [function_fixup_bc, off, bc_pos]
R 0 0 StoreI64 [function_fixup_target, off, target_slot]
R 0 0 Add [function_fixup_count, 1] function_fixup_count
R 0 0 Ret [0]
R 0 0 Label [fafu_full]
R 0 0 Ret [1]
R 0 0 EndF

# void func_resolve_fixups()
F 0 0 func_resolve_fixups []
R 0 0 Add [0, 0] i
R 0 0 Label [frf_loop]
R 0 0 Lt [i, function_fixup_count] cond
R 0 0 Jz [cond, frf_done]
R 0 0 Mul [i, 8] off
R 0 0 LoadI64 [function_fixup_target, off] slot
R 0 0 LoadI64 [function_fixup_bc, off] fixup_bc_pos
R 0 0 Mul [slot, 8] soff
R 0 0 LoadI64 [function_offsets, soff] target_off
R 0 0 Lt [target_off, 0] undef
R 0 0 Jz [undef, frf_patch]
R 0 0 Jmp [frf_next]
R 0 0 Label [frf_patch]
R 0 0 Add [fixup_bc_pos, 2] call_post
R 0 0 Sub [target_off, call_post] rel
R 0 0 BitAnd [rel, 255] rb0
R 0 0 StoreByte [g_bytecode, fixup_bc_pos, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 BitAnd [rs, 255] rb1
R 0 0 Add [fixup_bc_pos, 1] pos1
R 0 0 StoreByte [g_bytecode, pos1, rb1]
R 0 0 Label [frf_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [frf_loop]
R 0 0 Label [frf_done]
R 0 0 Ret []
R 0 0 EndF

# ============================================================================
# F.5 m_label - labels table + fixups (paralelo a compilador_777.c 386-481)
# ============================================================================

F 0 0 label_init []
R 0 0 Add [0, 0] i
R 0 0 Label [li_zname]
R 0 0 Lt [i, c_LABEL_NAMES_BYTES] cond
R 0 0 Jz [cond, li_zndone]
R 0 0 StoreByte [label_names, i, 0]
R 0 0 Add [i, 1] i
R 0 0 Jmp [li_zname]
R 0 0 Label [li_zndone]
R 0 0 Add [0, 0] i
R 0 0 Label [li_zoff]
R 0 0 Lt [i, c_MAX_LABELS] cond
R 0 0 Jz [cond, li_zodone]
R 0 0 Mul [i, 8] off
R 0 0 StoreI64 [label_offsets, off, -1]
R 0 0 Add [i, 1] i
R 0 0 Jmp [li_zoff]
R 0 0 Label [li_zodone]
R 0 0 Add [0, 0] label_count
R 0 0 Add [0, 0] label_fixup_count
R 0 0 Ret []
R 0 0 EndF

F 0 0 label_name_eq [slot, name, len]
R 0 0 Mul [slot, c_MAX_LABEL_NAME_LEN] base
R 0 0 Add [0, 0] i
R 0 0 Label [lne_loop]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, lne_post]
R 0 0 Add [base, i] off_a
R 0 0 LoadByte [label_names, off_a] b_a
R 0 0 LoadByte [name, i] b_b
R 0 0 Eq [b_a, b_b] cond
R 0 0 Jz [cond, lne_neq]
R 0 0 Add [i, 1] i
R 0 0 Jmp [lne_loop]
R 0 0 Label [lne_post]
R 0 0 Add [base, len] term_off
R 0 0 LoadByte [label_names, term_off] b_t
R 0 0 Eq [b_t, 0] cond
R 0 0 Jz [cond, lne_neq]
R 0 0 Ret [1]
R 0 0 Label [lne_neq]
R 0 0 Ret [0]
R 0 0 EndF

F 0 0 label_lookup_or_create [name, len]
R 0 0 Lt [0, len] valid
R 0 0 Jz [valid, llc_inv]
R 0 0 Sub [c_MAX_LABEL_NAME_LEN, 1] max_allowed
R 0 0 Gt [len, max_allowed] too_long
R 0 0 Jz [too_long, llc_lenok]
R 0 0 Ret [-1]
R 0 0 Label [llc_lenok]
R 0 0 Add [0, 0] slot
R 0 0 Label [llc_loop]
R 0 0 Lt [slot, label_count] cond
R 0 0 Jz [cond, llc_create]
R 0 0 Call [label_name_eq, slot, name, len] eqr
R 0 0 Jz [eqr, llc_next]
R 0 0 Ret [slot]
R 0 0 Label [llc_next]
R 0 0 Add [slot, 1] slot
R 0 0 Jmp [llc_loop]
R 0 0 Label [llc_create]
R 0 0 Lt [label_count, c_MAX_LABELS] cap
R 0 0 Jz [cap, llc_full]
R 0 0 Add [label_count, 0] slot
R 0 0 Mul [slot, c_MAX_LABEL_NAME_LEN] base
R 0 0 Add [0, 0] i
R 0 0 Label [llc_copy]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, llc_cdone]
R 0 0 Add [base, i] dst
R 0 0 LoadByte [name, i] b
R 0 0 StoreByte [label_names, dst, b]
R 0 0 Add [i, 1] i
R 0 0 Jmp [llc_copy]
R 0 0 Label [llc_cdone]
R 0 0 Add [base, len] term
R 0 0 StoreByte [label_names, term, 0]
R 0 0 Mul [slot, 8] off_i64
R 0 0 StoreI64 [label_offsets, off_i64, -1]
R 0 0 Add [label_count, 1] label_count
R 0 0 Ret [slot]
R 0 0 Label [llc_full]
R 0 0 Ret [-1]
R 0 0 Label [llc_inv]
R 0 0 Ret [-1]
R 0 0 EndF

F 0 0 label_add_fixup [bc_pos, target_slot]
R 0 0 Lt [label_fixup_count, c_MAX_LABEL_FIXUPS] cond
R 0 0 Jz [cond, laf_full]
R 0 0 Mul [label_fixup_count, 8] off
R 0 0 StoreI64 [label_fixup_bc, off, bc_pos]
R 0 0 StoreI64 [label_fixup_target, off, target_slot]
R 0 0 Add [label_fixup_count, 1] label_fixup_count
R 0 0 Ret [0]
R 0 0 Label [laf_full]
R 0 0 Ret [1]
R 0 0 EndF

F 0 0 label_resolve_fixups []
R 0 0 Add [0, 0] i
R 0 0 Label [lrf_loop]
R 0 0 Lt [i, label_fixup_count] cond
R 0 0 Jz [cond, lrf_done]
R 0 0 Mul [i, 8] off
R 0 0 LoadI64 [label_fixup_target, off] slot
R 0 0 LoadI64 [label_fixup_bc, off] fixup_bc_pos
R 0 0 Mul [slot, 8] soff
R 0 0 LoadI64 [label_offsets, soff] target_off
R 0 0 Lt [target_off, 0] undef
R 0 0 Jz [undef, lrf_patch]
R 0 0 Jmp [lrf_next]
R 0 0 Label [lrf_patch]
R 0 0 Add [fixup_bc_pos, 2] post
R 0 0 Sub [target_off, post] rel
R 0 0 BitAnd [rel, 255] rb0
R 0 0 StoreByte [g_bytecode, fixup_bc_pos, rb0]
R 0 0 Shr [rel, 8] rs
R 0 0 BitAnd [rs, 255] rb1
R 0 0 Add [fixup_bc_pos, 1] pos1
R 0 0 StoreByte [g_bytecode, pos1, rb1]
R 0 0 Label [lrf_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [lrf_loop]
R 0 0 Label [lrf_done]
R 0 0 Ret []
R 0 0 EndF

# int is_valid_ident(char* name, int len) -> 1 si valido
# [A-Za-z_][A-Za-z0-9_]{0,MAX_NAME_LEN-1}
# Lógica: primer char debe ser '_' o A-Z o a-z. Subsiguientes pueden incluir 0-9.
F 0 0 is_valid_ident [name, len]
R 0 0 Lt [0, len] valid
R 0 0 Jz [valid, iv_no]
R 0 0 Sub [c_MAX_NAME_LEN, 1] max_allowed
R 0 0 Gt [len, max_allowed] too_long
R 0 0 Jz [too_long, iv_lenok]
R 0 0 Jmp [iv_no]
R 0 0 Label [iv_lenok]
# Check primer char: '_' o A-Z o a-z
R 0 0 LoadByte [name, 0] c
R 0 0 Eq [c, 95] ok
R 0 0 Jz [ok, iv1_chk_upper]
R 0 0 Jmp [iv_first_ok]
R 0 0 Label [iv1_chk_upper]
R 0 0 Lt [c, 65] below_A
R 0 0 Jz [below_A, iv1_in_upper_range]
R 0 0 Jmp [iv1_chk_lower]
R 0 0 Label [iv1_in_upper_range]
R 0 0 Gt [c, 90] above_Z
R 0 0 Jz [above_Z, iv_first_ok]
R 0 0 Label [iv1_chk_lower]
R 0 0 Lt [c, 97] below_a
R 0 0 Jz [below_a, iv1_in_lower_range]
R 0 0 Jmp [iv_no]
R 0 0 Label [iv1_in_lower_range]
R 0 0 Gt [c, 122] above_z
R 0 0 Jz [above_z, iv_first_ok]
R 0 0 Jmp [iv_no]
R 0 0 Label [iv_first_ok]
# Loop chars subsiguientes
R 0 0 Add [1, 0] i
R 0 0 Label [iv_loop]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, iv_yes]
R 0 0 LoadByte [name, i] c
R 0 0 Eq [c, 95] ok
R 0 0 Jz [ok, iv2_chk_digit]
R 0 0 Jmp [iv_next]
R 0 0 Label [iv2_chk_digit]
R 0 0 Lt [c, 48] below_0
R 0 0 Jz [below_0, iv2_in_digit]
R 0 0 Jmp [iv2_chk_upper]
R 0 0 Label [iv2_in_digit]
R 0 0 Gt [c, 57] above_9
R 0 0 Jz [above_9, iv_next]
R 0 0 Label [iv2_chk_upper]
R 0 0 Lt [c, 65] below_A2
R 0 0 Jz [below_A2, iv2_in_upper]
R 0 0 Jmp [iv2_chk_lower]
R 0 0 Label [iv2_in_upper]
R 0 0 Gt [c, 90] above_Z2
R 0 0 Jz [above_Z2, iv_next]
R 0 0 Label [iv2_chk_lower]
R 0 0 Lt [c, 97] below_a2
R 0 0 Jz [below_a2, iv2_in_lower]
R 0 0 Jmp [iv_no]
R 0 0 Label [iv2_in_lower]
R 0 0 Gt [c, 122] above_z2
R 0 0 Jz [above_z2, iv_next]
R 0 0 Jmp [iv_no]
R 0 0 Label [iv_next]
R 0 0 Add [i, 1] i
R 0 0 Jmp [iv_loop]
R 0 0 Label [iv_yes]
R 0 0 Ret [1]
R 0 0 Label [iv_no]
R 0 0 Ret [0]
R 0 0 EndF

# ============================================================================
# F.6 m_helpers - sb + var_slot + parse_i64 + fits_in_i32 + bc_emit_* + elf_emit_*
# ============================================================================

# Global flag de error para parse_i64 (paralelo a int* err_out de C).
D 0 0 g_parse_err Integer 0

# int sb(int p) = g_source[p] zero-extended
F 0 0 sb [p]
R 0 0 LoadByte [g_source, p] b
R 0 0 Ret [b]
R 0 0 EndF

# int var_slot(int c) -> c-'A' si A-Z, sino -1
F 0 0 var_slot [c]
R 0 0 Lt [c, 65] below
R 0 0 Jz [below, vs_chk_upper]
R 0 0 Jmp [vs_neg]
R 0 0 Label [vs_chk_upper]
R 0 0 Gt [c, 90] above
R 0 0 Jz [above, vs_ok]
R 0 0 Jmp [vs_neg]
R 0 0 Label [vs_ok]
R 0 0 Sub [c, 65] slot
R 0 0 Ret [slot]
R 0 0 Label [vs_neg]
R 0 0 Ret [-1]
R 0 0 EndF

# int parse_i64(char* s, int len) -> val. Setea g_parse_err=0 si OK, 1 si error.
F 0 0 parse_i64 [s, len]
R 0 0 Add [0, 0] g_parse_err
R 0 0 Eq [len, 0] empty
R 0 0 Jz [empty, pi_lenok]
R 0 0 Add [1, 0] g_parse_err
R 0 0 Ret [0]
R 0 0 Label [pi_lenok]
R 0 0 Add [0, 0] neg
R 0 0 Add [0, 0] i
R 0 0 LoadByte [s, 0] b0
R 0 0 Eq [b0, 45] is_neg
R 0 0 Jz [is_neg, pi_parse]
R 0 0 Add [1, 0] neg
R 0 0 Add [1, 0] i
R 0 0 Eq [len, 1] only_minus
R 0 0 Jz [only_minus, pi_parse]
R 0 0 Add [1, 0] g_parse_err
R 0 0 Ret [0]
R 0 0 Label [pi_parse]
R 0 0 Add [0, 0] acc
R 0 0 Label [pi_loop]
R 0 0 Lt [i, len] cond
R 0 0 Jz [cond, pi_done]
R 0 0 LoadByte [s, i] b
R 0 0 Lt [b, 48] bad_low
R 0 0 Jz [bad_low, pi_chk_high]
R 0 0 Jmp [pi_err]
R 0 0 Label [pi_chk_high]
R 0 0 Gt [b, 57] bad_high
R 0 0 Jz [bad_high, pi_acc]
R 0 0 Jmp [pi_err]
R 0 0 Label [pi_acc]
R 0 0 Mul [acc, 10] acc10
R 0 0 Sub [b, 48] dig
R 0 0 Add [acc10, dig] acc
R 0 0 Add [i, 1] i
R 0 0 Jmp [pi_loop]
R 0 0 Label [pi_done]
R 0 0 Eq [neg, 1] is_n
R 0 0 Jz [is_n, pi_pos]
R 0 0 Sub [0, acc] negval
R 0 0 Ret [negval]
R 0 0 Label [pi_pos]
R 0 0 Ret [acc]
R 0 0 Label [pi_err]
R 0 0 Add [1, 0] g_parse_err
R 0 0 Ret [0]
R 0 0 EndF

# int fits_in_i32(int v) -> 1 si -2^31 <= v <= 2^31 - 1
D 0 0 c_INT32_MIN Integer -2147483648
D 0 0 c_INT32_MAX Integer 2147483647
F 0 0 fits_in_i32 [v]
R 0 0 Lt [v, 0] is_neg
R 0 0 Jz [is_neg, fi_pos_path]
R 0 0 Lt [v, c_INT32_MIN] below_min
R 0 0 Jz [below_min, fi_yes]
R 0 0 Ret [0]
R 0 0 Label [fi_pos_path]
R 0 0 Gt [v, c_INT32_MAX] above_max
R 0 0 Jz [above_max, fi_yes]
R 0 0 Ret [0]
R 0 0 Label [fi_yes]
R 0 0 Ret [1]
R 0 0 EndF

# void bc_emit(int b)
F 0 0 bc_emit [b]
R 0 0 BitAnd [b, 255] bm
R 0 0 StoreByte [g_bytecode, g_bytecode_len, bm]
R 0 0 Add [g_bytecode_len, 1] g_bytecode_len
R 0 0 Ret []
R 0 0 EndF

# void bc_emit_imm32(int v) -> 4 bytes LE
F 0 0 bc_emit_imm32 [v]
R 0 0 Call [bc_emit, v]
R 0 0 Shr [v, 8] v1
R 0 0 Call [bc_emit, v1]
R 0 0 Shr [v, 16] v2
R 0 0 Call [bc_emit, v2]
R 0 0 Shr [v, 24] v3
R 0 0 Call [bc_emit, v3]
R 0 0 Ret []
R 0 0 EndF

# void bc_emit_slot(int s): Lote 4 dual opcode. Si s<256 emite 1 byte.
# Si s>=256: backpatch byte anterior OP_LOAD_VAR(6)->OP_LOAD_VAR16(50),
# OP_STORE_VAR(7)->OP_STORE_VAR16(51), emite 2 bytes LE.
F 0 0 bc_emit_slot [s]
R 0 0 Lt [s, 256] is_small
R 0 0 Jz [is_small, bes_big]
R 0 0 Call [bc_emit, s]
R 0 0 Ret []
R 0 0 Label [bes_big]
R 0 0 Sub [g_bytecode_len, 1] prev_pos
R 0 0 LoadByte [g_bytecode, prev_pos] prev
R 0 0 Eq [prev, 6] is_load
R 0 0 Jz [is_load, bes_chk_store]
R 0 0 StoreByte [g_bytecode, prev_pos, 50]
R 0 0 Jmp [bes_emit_slot]
R 0 0 Label [bes_chk_store]
R 0 0 Eq [prev, 7] is_store
R 0 0 Jz [is_store, bes_emit_slot]
R 0 0 StoreByte [g_bytecode, prev_pos, 51]
R 0 0 Label [bes_emit_slot]
R 0 0 BitAnd [s, 255] lo
R 0 0 Call [bc_emit, lo]
R 0 0 Shr [s, 8] hi
R 0 0 BitAnd [hi, 255] hi2
R 0 0 Call [bc_emit, hi2]
R 0 0 Ret []
R 0 0 EndF

# void bc_emit_imm64(int v) -> 8 bytes LE
F 0 0 bc_emit_imm64 [v]
R 0 0 Call [bc_emit, v]
R 0 0 Shr [v, 8] v1
R 0 0 Call [bc_emit, v1]
R 0 0 Shr [v, 16] v2
R 0 0 Call [bc_emit, v2]
R 0 0 Shr [v, 24] v3
R 0 0 Call [bc_emit, v3]
R 0 0 Shr [v, 32] v4
R 0 0 Call [bc_emit, v4]
R 0 0 Shr [v, 40] v5
R 0 0 Call [bc_emit, v5]
R 0 0 Shr [v, 48] v6
R 0 0 Call [bc_emit, v6]
R 0 0 Shr [v, 56] v7
R 0 0 Call [bc_emit, v7]
R 0 0 Ret []
R 0 0 EndF

# void elf_emit_at(int off, int b)
F 0 0 elf_emit_at [off, b]
R 0 0 BitAnd [b, 255] bm
R 0 0 StoreByte [g_elf, off, bm]
R 0 0 Ret []
R 0 0 EndF

# void elf_emit_u16_at(int off, int v)
F 0 0 elf_emit_u16_at [off, v]
R 0 0 BitAnd [v, 255] b0
R 0 0 StoreByte [g_elf, off, b0]
R 0 0 Shr [v, 8] s1
R 0 0 BitAnd [s1, 255] b1
R 0 0 Add [off, 1] off1
R 0 0 StoreByte [g_elf, off1, b1]
R 0 0 Ret []
R 0 0 EndF

# void elf_emit_u32_at(int off, int v)
F 0 0 elf_emit_u32_at [off, v]
R 0 0 BitAnd [v, 255] b0
R 0 0 StoreByte [g_elf, off, b0]
R 0 0 Shr [v, 8] s1
R 0 0 BitAnd [s1, 255] b1
R 0 0 Add [off, 1] off1
R 0 0 StoreByte [g_elf, off1, b1]
R 0 0 Shr [v, 16] s2
R 0 0 BitAnd [s2, 255] b2
R 0 0 Add [off, 2] off2
R 0 0 StoreByte [g_elf, off2, b2]
R 0 0 Shr [v, 24] s3
R 0 0 BitAnd [s3, 255] b3
R 0 0 Add [off, 3] off3
R 0 0 StoreByte [g_elf, off3, b3]
R 0 0 Ret []
R 0 0 EndF

# void elf_emit_u64_at(int off, int v)
F 0 0 elf_emit_u64_at [off, v]
R 0 0 BitAnd [v, 255] b0
R 0 0 StoreByte [g_elf, off, b0]
R 0 0 Shr [v, 8] s1
R 0 0 BitAnd [s1, 255] b1
R 0 0 Add [off, 1] off1
R 0 0 StoreByte [g_elf, off1, b1]
R 0 0 Shr [v, 16] s2
R 0 0 BitAnd [s2, 255] b2
R 0 0 Add [off, 2] off2
R 0 0 StoreByte [g_elf, off2, b2]
R 0 0 Shr [v, 24] s3
R 0 0 BitAnd [s3, 255] b3
R 0 0 Add [off, 3] off3
R 0 0 StoreByte [g_elf, off3, b3]
R 0 0 Shr [v, 32] s4
R 0 0 BitAnd [s4, 255] b4
R 0 0 Add [off, 4] off4
R 0 0 StoreByte [g_elf, off4, b4]
R 0 0 Shr [v, 40] s5
R 0 0 BitAnd [s5, 255] b5
R 0 0 Add [off, 5] off5
R 0 0 StoreByte [g_elf, off5, b5]
R 0 0 Shr [v, 48] s6
R 0 0 BitAnd [s6, 255] b6
R 0 0 Add [off, 6] off6
R 0 0 StoreByte [g_elf, off6, b6]
R 0 0 Shr [v, 56] s7
R 0 0 BitAnd [s7, 255] b7
R 0 0 Add [off, 7] off7
R 0 0 StoreByte [g_elf, off7, b7]
R 0 0 Ret []
R 0 0 EndF

# ============================================================================
# F.7 m_arch_x86 - bytes handlers AMD64 + emit primitives (paralelo arch_x86.c)
# ============================================================================
# Layout:
#   arch_all_handlers = buffer con todos los handler bytes concatenados (~541 B).
#   arch_handler_offsets[idx] = offset en arch_all_handlers (i64).
#   arch_handler_sizes_tbl[idx] = size del handler (i64).
#   arch_cursor = cursor durante arch_init para construir buffer.

D 0 0 c_HANDLERS_BUF_SIZE Integer 1024
D 0 0 c_HANDLER_TABLE_BYTES Integer 512
R 0 0 Alloc [c_HANDLERS_BUF_SIZE]   arch_all_handlers
R 0 0 Alloc [c_HANDLER_TABLE_BYTES] arch_handler_offsets
R 0 0 Alloc [c_HANDLER_TABLE_BYTES] arch_handler_sizes_tbl
D 0 0 arch_cursor Integer 0

# Append byte al buffer + avanza cursor.
F 0 0 arch_ab [b]
R 0 0 BitAnd [b, 255] bm
R 0 0 StoreByte [arch_all_handlers, arch_cursor, bm]
R 0 0 Add [arch_cursor, 1] arch_cursor
R 0 0 Ret []
R 0 0 EndF

# Registra handler idx: offset = arch_cursor actual, size = size.
F 0 0 arch_reg [idx, size]
R 0 0 Mul [idx, 8] off
R 0 0 StoreI64 [arch_handler_offsets, off, arch_cursor]
R 0 0 StoreI64 [arch_handler_sizes_tbl, off, size]
R 0 0 Ret []
R 0 0 EndF

# Inicializa tablas de handlers con bytes x86 hardcoded (paralelo arch_x86.c h_*).
F 0 0 arch_init []
R 0 0 Add [0, 0] arch_cursor
# idx 0 HALT (2): EB 00
R 0 0 Call [arch_reg, 0, 2]
R 0 0 Call [arch_ab, 235]
R 0 0 Call [arch_ab, 0]
# idx 1 LOAD_IMM32 (8): 49 63 07 49 83 C7 04 50
R 0 0 Call [arch_reg, 1, 8]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 99]
R 0 0 Call [arch_ab, 7]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 131]
R 0 0 Call [arch_ab, 199]
R 0 0 Call [arch_ab, 4]
R 0 0 Call [arch_ab, 80]
# idx 2 ADD (6): 58 59 48 01 C8 50
R 0 0 Call [arch_reg, 2, 6]
R 0 0 Call [arch_ab, 88]
R 0 0 Call [arch_ab, 89]
R 0 0 Call [arch_ab, 72]
R 0 0 Call [arch_ab, 1]
R 0 0 Call [arch_ab, 200]
R 0 0 Call [arch_ab, 80]
# idx 3 SUB (6): 59 58 48 29 C8 50
R 0 0 Call [arch_reg, 3, 6]
R 0 0 Call [arch_ab, 89]
R 0 0 Call [arch_ab, 88]
R 0 0 Call [arch_ab, 72]
R 0 0 Call [arch_ab, 41]
R 0 0 Call [arch_ab, 200]
R 0 0 Call [arch_ab, 80]
# idx 4 MUL (7): 58 59 48 0F AF C1 50
R 0 0 Call [arch_reg, 4, 7]
R 0 0 Call [arch_ab, 88]
R 0 0 Call [arch_ab, 89]
R 0 0 Call [arch_ab, 72]
R 0 0 Call [arch_ab, 15]
R 0 0 Call [arch_ab, 175]
R 0 0 Call [arch_ab, 193]
R 0 0 Call [arch_ab, 80]
# idx 5 ADD_R12 (4): 58 49 01 C4
R 0 0 Call [arch_reg, 5, 4]
R 0 0 Call [arch_ab, 88]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 1]
R 0 0 Call [arch_ab, 196]
# idx 6 LOAD_VAR (11): 49 0F B6 07 49 FF C7 FF 74 C5 00
R 0 0 Call [arch_reg, 6, 11]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 15]
R 0 0 Call [arch_ab, 182]
R 0 0 Call [arch_ab, 7]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 255]
R 0 0 Call [arch_ab, 199]
R 0 0 Call [arch_ab, 255]
R 0 0 Call [arch_ab, 116]
R 0 0 Call [arch_ab, 197]
R 0 0 Call [arch_ab, 0]
# idx 7 STORE_VAR (11): 49 0F B6 07 49 FF C7 8F 44 C5 00
R 0 0 Call [arch_reg, 7, 11]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 15]
R 0 0 Call [arch_ab, 182]
R 0 0 Call [arch_ab, 7]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 255]
R 0 0 Call [arch_ab, 199]
R 0 0 Call [arch_ab, 143]
R 0 0 Call [arch_ab, 68]
R 0 0 Call [arch_ab, 197]
R 0 0 Call [arch_ab, 0]
# idx 8 JMP (11): 49 0F BF 07 49 83 C7 02 49 01 C7
R 0 0 Call [arch_reg, 8, 11]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 15]
R 0 0 Call [arch_ab, 191]
R 0 0 Call [arch_ab, 7]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 131]
R 0 0 Call [arch_ab, 199]
R 0 0 Call [arch_ab, 2]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 1]
R 0 0 Call [arch_ab, 199]
# idx 9 JZ (17): 59 49 0F BF 07 49 83 C7 02 48 85 C9 75 03 49 01 C7
R 0 0 Call [arch_reg, 9, 17]
R 0 0 Call [arch_ab, 89]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 15]
R 0 0 Call [arch_ab, 191]
R 0 0 Call [arch_ab, 7]
R 0 0 Call [arch_ab, 73]
R 0 0 Call [arch_ab, 131]
R 0 0 Call [arch_ab, 199]
R 0 0 Call [arch_ab, 2]
R 0 0 Call [arch_ab, 72]
R 0 0 Call [arch_ab, 133]
R 0 0 Call [arch_ab, 201]
R 0 0 Call [arch_ab, 117]
R 0 0 Call [arch_ab, 3]
