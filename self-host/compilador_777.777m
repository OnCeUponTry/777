R 0 0 Call [func_add_fixup, g_bytecode_len, call_slot] _
R 0 0 Call [bc_emit, 0]
R 0 0 Call [bc_emit, 0]
R 0 0 Jmp [hc_result]
R 0 0 Label [hc_call_resolve]
R 0 0 Add [g_bytecode_len, 2] cpost
R 0 0 Sub [foff, cpost] crel
R 0 0 BitAnd [crel, 255] rb0
R 0 0 Call [bc_emit, rb0]
R 0 0 Shr [crel, 8] rs
R 0 0 Call [bc_emit, rs]
R 0 0 Label [hc_result]
# Parse result slot post-]
R 0 0 Call [clr_skip_ws, line_end]
R 0 0 Add [parse_pos, 0] result_start
R 0 0 Label [hc_r_loop]
R 0 0 Lt [parse_pos, line_end] cond
R 0 0 Jz [cond, hc_r_end]
R 0 0 LoadByte [g_source, parse_pos] cc
R 0 0 Eq [cc, 32] s1
R 0 0 Jz [s1, hc_r_t]
R 0 0 Jmp [hc_r_end]
R 0 0 Label [hc_r_t]
R 0 0 Eq [cc, 9] s2
R 0 0 Jz [s2, hc_r_n]
R 0 0 Jmp [hc_r_end]
R 0 0 Label [hc_r_n]
R 0 0 Eq [cc, 10] s3
R 0 0 Jz [s3, hc_r_cr]
