R 0 0 Jmp [hc_done]
R 0 0 Label [hc_emit_store]
R 0 0 Call [bc_emit, 7]
R 0 0 Call [bc_emit_slot, rslot]
R 0 0 Jmp [hc_done]
R 0 0 Label [hc_drop]
R 0 0 Call [bc_emit, 7]
R 0 0 Call [bc_emit_slot, c_DROP_SLOT]
