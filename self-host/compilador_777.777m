R 0 0 Call [elf_emit_at, p, 72]
R 0 0 Add [base, 8] p
R 0 0 Call [elf_emit_at, p, 141]
R 0 0 Add [base, 9] p
R 0 0 Call [elf_emit_at, p, 13]
R 0 0 Add [base, 10] p
R 0 0 Call [elf_emit_u32_at, p, jt_disp]
