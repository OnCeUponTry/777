R 0 0 Jmp [hef_reset_slot]
R 0 0 Label [hef_patch]
R 0 0 Add [pending_fn_jmp_pos, 2] post
R 0 0 Sub [g_bytecode_len, post] rel
R 0 0 BitAnd [rel, 255] rb0
