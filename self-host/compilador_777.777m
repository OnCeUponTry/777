R 0 0 Add [base, 10] p
R 0 0 Call [elf_emit_at, p, 15]
R 0 0 Add [base, 11] p
R 0 0 Call [elf_emit_at, p, 5]
R 0 0 Ret []
R 0 0 EndF

# Emit jmp near + disp32: E9 + disp32 (5 bytes)
F 0 0 arch_emit_jmp_back [base, disp]
R 0 0 Call [elf_emit_at, base, 233]
R 0 0 Add [base, 1] p
R 0 0 Call [elf_emit_u32_at, p, disp]
R 0 0 Ret []
R 0 0 EndF

# Patch HALT marker: sobreescribe 2 bytes con jmp near (5 bytes)
F 0 0 arch_emit_halt_jmp [base, disp]
R 0 0 Call [arch_emit_jmp_back, base, disp]
R 0 0 Ret []
R 0 0 EndF

# ============================================================================
# F.9 m_parser_helpers - parser helpers (paralelo compilador_777.c 1078-1233)
# ============================================================================
# Convencion: parse_pos es global mutable. F lo leen y avanzan.
# Tokens devuelven (token_start_off, token_len) en globals g_tok_off / g_tok_len.

D 0 0 parse_pos Integer 0
D 0 0 g_tok_off Integer 0
D 0 0 g_tok_len Integer 0

# void skip_to_eol(): avanza parse_pos despues del primer '\n'.
F 0 0 skip_to_eol [end]
R 0 0 Label [ste_loop]
R 0 0 Lt [parse_pos, end] cond
R 0 0 Jz [cond, ste_done]
R 0 0 LoadByte [g_source, parse_pos] b
R 0 0 Eq [b, 10] is_nl
R 0 0 Jz [is_nl, ste_skip_inc]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Ret []
R 0 0 Label [ste_skip_inc]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [ste_loop]
R 0 0 Label [ste_done]
R 0 0 Ret []
R 0 0 EndF

# void next_token(end): setea g_tok_off / g_tok_len y avanza parse_pos.
# Soporta quoted strings con escapes.
F 0 0 next_token [end]
# Skip ws
R 0 0 Label [nt_skip]
R 0 0 Lt [parse_pos, end] cond
R 0 0 Jz [cond, nt_done_skip]
R 0 0 LoadByte [g_source, parse_pos] c
R 0 0 Eq [c, 32] is_sp
R 0 0 Jz [is_sp, nt_chk_tab]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [nt_skip]
R 0 0 Label [nt_chk_tab]
R 0 0 Eq [c, 9] is_tab
R 0 0 Jz [is_tab, nt_done_skip]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [nt_skip]
R 0 0 Label [nt_done_skip]
R 0 0 Add [parse_pos, 0] start
# Si quoted "...":
R 0 0 Lt [parse_pos, end] cond
R 0 0 Jz [cond, nt_normal]
R 0 0 LoadByte [g_source, parse_pos] c
R 0 0 Eq [c, 34] is_quote
R 0 0 Jz [is_quote, nt_normal]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Label [nt_qloop]
R 0 0 Lt [parse_pos, end] cond
R 0 0 Jz [cond, nt_qdone]
R 0 0 LoadByte [g_source, parse_pos] c
R 0 0 Eq [c, 34] is_close
R 0 0 Jz [is_close, nt_qchk_esc]
R 0 0 Jmp [nt_qdone]
R 0 0 Label [nt_qchk_esc]
R 0 0 Eq [c, 92] is_esc
R 0 0 Jz [is_esc, nt_qadv1]
R 0 0 Add [parse_pos, 1] next_p
R 0 0 Lt [next_p, end] within
R 0 0 Jz [within, nt_qadv1]
R 0 0 Add [parse_pos, 2] parse_pos
R 0 0 Jmp [nt_qloop]
R 0 0 Label [nt_qadv1]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [nt_qloop]
R 0 0 Label [nt_qdone]
R 0 0 Lt [parse_pos, end] cond
R 0 0 Jz [cond, nt_qend]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Label [nt_qend]
R 0 0 Sub [parse_pos, start] len_v
R 0 0 Add [start, 0] g_tok_off
R 0 0 Add [len_v, 0] g_tok_len
R 0 0 Ret []
R 0 0 Label [nt_normal]
R 0 0 Label [nt_nloop]
R 0 0 Lt [parse_pos, end] cond
R 0 0 Jz [cond, nt_ndone]
R 0 0 LoadByte [g_source, parse_pos] c
R 0 0 Eq [c, 32] is_sp
R 0 0 Jz [is_sp, nt_chk_t]
R 0 0 Jmp [nt_ndone]
R 0 0 Label [nt_chk_t]
R 0 0 Eq [c, 9] is_t
R 0 0 Jz [is_t, nt_chk_nl]
R 0 0 Jmp [nt_ndone]
R 0 0 Label [nt_chk_nl]
R 0 0 Eq [c, 10] is_n
R 0 0 Jz [is_n, nt_chk_cr]
R 0 0 Jmp [nt_ndone]
R 0 0 Label [nt_chk_cr]
R 0 0 Eq [c, 13] is_r
R 0 0 Jz [is_r, nt_advance]
R 0 0 Jmp [nt_ndone]
R 0 0 Label [nt_advance]
R 0 0 Add [parse_pos, 1] parse_pos
R 0 0 Jmp [nt_nloop]
R 0 0 Label [nt_ndone]
R 0 0 Sub [parse_pos, start] len_v
R 0 0 Add [start, 0] g_tok_off
R 0 0 Add [len_v, 0] g_tok_len
R 0 0 Ret []
R 0 0 EndF

# int eq_str_lit(int a_off, int alen, char* lit) -> 1 si bytes en g_source[a_off..a_off+alen]
# coinciden EXACTAMENTE con lit (terminado en 0).
F 0 0 eq_str_lit [a_off, alen, lit]
R 0 0 Add [0, 0] i
R 0 0 Label [esl_loop]
R 0 0 Lt [i, alen] cond
R 0 0 Jz [cond, esl_post]
R 0 0 LoadByte [lit, i] b_lit
R 0 0 Eq [b_lit, 0] hit_zero
R 0 0 Jz [hit_zero, esl_compare]
R 0 0 Ret [0]
R 0 0 Label [esl_compare]
R 0 0 Add [a_off, i] src_pos
R 0 0 LoadByte [g_source, src_pos] b_src
R 0 0 Eq [b_lit, b_src] match
R 0 0 Jz [match, esl_neq]
R 0 0 Add [i, 1] i
R 0 0 Jmp [esl_loop]
R 0 0 Label [esl_post]
R 0 0 LoadByte [lit, alen] b_term
R 0 0 Eq [b_term, 0] is_term
R 0 0 Jz [is_term, esl_neq]
R 0 0 Ret [1]
R 0 0 Label [esl_neq]
R 0 0 Ret [0]
R 0 0 EndF

# int is_valid_ident_at(int off, int len): adaptador. Lee bytes de g_source.
F 0 0 is_valid_ident_at [off, len]
R 0 0 Add [g_source, off] ptr
R 0 0 Call [is_valid_ident, ptr, len] r
R 0 0 Ret [r]
R 0 0 EndF

# int parse_i64_at(int off, int len): adaptador.
F 0 0 parse_i64_at [off, len]
R 0 0 Add [g_source, off] ptr
R 0 0 Call [parse_i64, ptr, len] r
R 0 0 Ret [r]
R 0 0 EndF

# int emit_load_arg_at(int arg_off, int alen): emite LOAD_VAR si ident, sino LOAD_IMM32/64.
# Retorna 0 OK, 1 si error.
F 0 0 emit_load_arg_at [arg_off, alen]
R 0 0 Eq [alen, 0] empty
R 0 0 Jz [empty, ela_lenok]
R 0 0 Ret [1]
R 0 0 Label [ela_lenok]
R 0 0 Call [is_valid_ident_at, arg_off, alen] is_ident
R 0 0 Jz [is_ident, ela_try_num]
R 0 0 Add [g_source, arg_off] name_ptr
R 0 0 Call [sym_intern, name_ptr, alen] slot
R 0 0 Lt [slot, 0] bad
R 0 0 Jz [bad, ela_emit_var]
R 0 0 Ret [1]
R 0 0 Label [ela_emit_var]
R 0 0 Call [bc_emit, 6]
R 0 0 Call [bc_emit_slot, slot]
R 0 0 Ret [0]
R 0 0 Label [ela_try_num]
R 0 0 Call [parse_i64_at, arg_off, alen] val
R 0 0 Eq [g_parse_err, 0] ok
R 0 0 Jz [ok, ela_ret_fail]
R 0 0 Label [ela_emit_num]
R 0 0 Call [fits_in_i32, val] is32
R 0 0 Jz [is32, ela_emit64]
R 0 0 Call [bc_emit, 1]
R 0 0 Call [bc_emit_imm32, val]
R 0 0 Ret [0]
R 0 0 Label [ela_emit64]
R 0 0 Call [bc_emit, 22]
R 0 0 Call [bc_emit_imm64, val]
R 0 0 Ret [0]
R 0 0 Label [ela_ret_fail]
R 0 0 Ret [1]
R 0 0 EndF

