# Combina F + loop + Alloc + StoreByte para diagnostic
# pi_n=42. Loop: Mod 10, Div 10, until 0. Exit con ultimo pi_d (4 al final).
# Sin StoreByte/FdWrite. Si funciona exit=4.
D 0 0 zero Integer 0
D 0 0 one Integer 1
D 0 0 ten Integer 10
D 0 0 pi_n Integer 42
D 0 0 pi_q Integer 0
D 0 0 pi_d Integer 0
D 0 0 pi_done Integer 0

F 0 0 loop_extract []
R 0 0 Add [pi_n, zero] pi_q
R 0 0 Mod [pi_q, ten] pi_d
R 0 0 Div [pi_q, ten] pi_q
R 0 0 Eq [pi_q, zero] pi_done
R 0 0 Jz [pi_done, -26]
R 0 0 Ret []
R 0 0 EndF

R 0 0 Call [loop_extract]
R 0 0 ExitTop [pi_d]
